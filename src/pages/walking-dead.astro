  /* Radar sweep on hero background circles — very slow */
  .hero-bg {
    animation: radarSweep 90s linear infinite;
  }

  /* Reveal on scroll */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out;
  }
  .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }

</style>
