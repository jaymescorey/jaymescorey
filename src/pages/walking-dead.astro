<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow">
<title>A Digital Home Worthy of The Walking Dead — Proposal for 1/9 Association</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://api.fontshare.com/v2/css?f[]=clash-display@700,600,500&f[]=general-sans@600,500,400&f[]=satoshi@700,500,400&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Special+Elite&display=swap" rel="stylesheet">
<style>
  :root {
    --marines-green: #293024;
    --marines-green-90: #404538;
    --deep-green: #171A17;
    --charcoal: #242424;
    --black: #0E0E0E;
    --marines-yellow: #F2B51A;
    --marines-red: #CC0F1F;
    --sand: #FAF7F2;
    --bone: #EFE4CE;
    --white: #FFFFFF;

    --font-display: 'Clash Display', sans-serif;
    --font-sub: 'General Sans', sans-serif;
    --font-body: 'Satoshi', sans-serif;
    --font-stencil: 'Special Elite', monospace;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--deep-green);
    color: var(--sand);
    font-family: var(--font-body);
    font-weight: 400;
    line-height: 1.6;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  /* Paper grain texture overlay — subtle, applied globally */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' /%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.35'/%3E%3C/svg%3E");
    pointer-events: none;
    opacity: 0.08;
    z-index: 1;
    mix-blend-mode: overlay;
  }

  /* ============ SHARED COMPONENTS ============ */

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 48px;
    position: relative;
    z-index: 2;
  }

  @media (max-width: 768px) {
    .container { padding: 0 24px; }
  }

  /* Bracket micro-assets */
  .brackets {
    position: relative;
    display: inline-block;
    padding: 0.25em 0.6em;
  }
  .brackets::before, .brackets::after {
    content: '';
    position: absolute;
    width: 14px;
    height: 14px;
    border: 2px solid var(--marines-yellow);
  }
  .brackets::before {
    top: 0; left: 0;
    border-right: none; border-bottom: none;
  }
  .brackets::after {
    bottom: 0; right: 0;
    border-left: none; border-top: none;
  }

  /* Section label — the red arrow + caps style from the brand guide */
  .section-label {
    font-family: var(--font-sub);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sand);
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 24px;
  }
  .section-label::before {
    content: '';
    display: inline-block;
    width: 10px;
    height: 10px;
    background: var(--marines-red);
    clip-path: polygon(0 0, 100% 0, 100% 60%, 60% 60%, 60% 100%, 0 60%);
    transform: rotate(-45deg);
  }

  /* Decorative stencil text with bracket frame */
  .stencil {
    font-family: var(--font-stencil);
    color: var(--marines-yellow);
    font-size: 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: inline-block;
    padding: 8px 16px;
    position: relative;
  }
  .stencil::before, .stencil::after {
    content: '';
    position: absolute;
    width: 10px; height: 10px;
    border: 2px solid var(--marines-yellow);
  }
  .stencil::before { top: 0; left: 0; border-right: none; border-bottom: none; }
  .stencil::after { bottom: 0; right: 0; border-left: none; border-top: none; }

  /* ============ TOP BAR ============ */

  .topbar {
    position: relative;
    z-index: 10;
    padding: 24px 0;
    border-bottom: 1px solid rgba(242, 181, 26, 0.15);
  }
  .topbar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-sub);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(250, 247, 242, 0.6);
  }
  .topbar-left {
    display: flex;
    gap: 24px;
    align-items: center;
  }
  .topbar-left .stencil-small {
    font-family: var(--font-stencil);
    color: var(--marines-yellow);
    font-size: 11px;
  }
  @media (max-width: 640px) {
    .topbar-right { display: none; }
  }

  /* ============ HERO SECTION ============ */

  .hero {
    position: relative;
    min-height: 100vh;
    padding: 80px 0 120px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  /* Decorative reaper background — abstract shapes standing in for the illustrated reaper */
  .hero-bg {
    position: absolute;
    right: -200px;
    top: 50%;
    transform: translateY(-50%);
    width: 900px;
    height: 900px;
    opacity: 0.06;
    pointer-events: none;
    z-index: 1;
  }

  .hero-crosshair {
    position: absolute;
    top: 120px;
    right: 80px;
    width: 60px;
    height: 60px;
    opacity: 0.5;
    z-index: 2;
  }
  .hero-crosshair::before, .hero-crosshair::after {
    content: '';
    position: absolute;
    background: var(--marines-yellow);
  }
  .hero-crosshair::before {
    top: 50%; left: 0; right: 0; height: 1px;
  }
  .hero-crosshair::after {
    left: 50%; top: 0; bottom: 0; width: 1px;
  }
  .hero-crosshair-dot {
    position: absolute;
    top: 50%; left: 50%;
    width: 10px; height: 10px;
    border: 1px solid var(--marines-yellow);
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }
  @media (max-width: 768px) {
    .hero-crosshair { display: none; }
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
    position: relative;
    z-index: 3;
  }
  .hero-eyebrow-line {
    width: 60px;
    height: 1px;
    background: var(--marines-yellow);
  }
  .hero-eyebrow-text {
    font-family: var(--font-sub);
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--marines-yellow);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(48px, 8.5vw, 128px);
    line-height: 0.85;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 48px;
    position: relative;
    z-index: 3;
    max-width: 1100px;
  }
  .hero-headline .accent {
    color: var(--marines-yellow);
    display: inline-block;
  }
  .hero-headline .outlined {
    -webkit-text-stroke: 2px var(--sand);
    color: transparent;
    display: inline-block;
  }

  .hero-meta {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    max-width: 900px;
    margin-top: 48px;
    padding-top: 40px;
    border-top: 1px solid rgba(242, 181, 26, 0.2);
    position: relative;
    z-index: 3;
  }
  @media (max-width: 768px) {
    .hero-meta { grid-template-columns: repeat(2, 1fr); gap: 24px; }
  }
  .hero-meta-item .label {
    font-family: var(--font-sub);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(250, 247, 242, 0.5);
    margin-bottom: 8px;
    display: block;
  }
  .hero-meta-item .value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 18px;
    color: var(--sand);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .hero-meta-item .value.yellow {
    color: var(--marines-yellow);
  }

  /* Tagline ribbon at bottom of hero */
  .hero-tagline {
    position: absolute;
    bottom: 40px;
    left: 48px;
    right: 48px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    z-index: 3;
  }
  @media (max-width: 768px) {
    .hero-tagline { position: relative; bottom: auto; left: auto; right: auto; margin-top: 60px; flex-direction: column; gap: 20px; align-items: flex-start; padding: 0 24px; }
  }
  .hero-tagline-block {
    font-family: var(--font-sub);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(250, 247, 242, 0.6);
    line-height: 1.6;
  }
  .hero-tagline-block strong {
    color: var(--sand);
    font-weight: 500;
    display: block;
  }

  /* ============ LETTER / OPENING SECTION ============ */

  .letter {
    background: var(--sand);
    color: var(--deep-green);
    padding: 140px 0;
    position: relative;
  }

  .letter::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 12px;
    background: var(--marines-yellow);
  }

  .letter-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 80px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .letter-grid { grid-template-columns: 1fr; gap: 40px; }
  }

  .letter-side .section-label {
    color: var(--deep-green);
  }
  .letter-side .section-label::before {
    background: var(--marines-red);
  }

  .letter-side h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(32px, 4vw, 56px);
    line-height: 0.9;
    text-transform: uppercase;
    color: var(--deep-green);
    letter-spacing: -0.01em;
  }

  .letter-body {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.75;
    color: var(--deep-green);
  }
  .letter-body p { margin-bottom: 20px; }
  .letter-body p:last-child { margin-bottom: 0; }
  .letter-body .lead {
    font-size: 22px;
    line-height: 1.5;
    font-weight: 500;
    margin-bottom: 28px;
    color: var(--charcoal);
  }
  .letter-body strong {
    color: var(--deep-green);
    font-weight: 700;
  }

  /* ============ WHAT I HEARD ============ */

  .heard {
    background: var(--charcoal);
    padding: 140px 0;
    position: relative;
  }

  .heard-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 80px;
    gap: 40px;
    flex-wrap: wrap;
  }

  .heard-header h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(40px, 6vw, 88px);
    line-height: 0.85;
    text-transform: uppercase;
    color: var(--sand);
    letter-spacing: -0.02em;
    max-width: 700px;
  }
  .heard-header h2 em {
    font-style: normal;
    color: var(--marines-yellow);
  }

  .heard-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 900px) {
    .heard-grid { grid-template-columns: 1fr; }
  }

  .heard-card {
    background: var(--deep-green);
    padding: 40px 32px;
    position: relative;
    border-left: 3px solid var(--marines-yellow);
    /* Ribbon-shaped container — cut corner top right */
    clip-path: polygon(0 0, calc(100% - 24px) 0, 100% 24px, 100% 100%, 0 100%);
  }

  .heard-card-num {
    font-family: var(--font-stencil);
    font-size: 12px;
    color: var(--marines-yellow);
    letter-spacing: 0.15em;
    margin-bottom: 20px;
    display: block;
  }

  .heard-card h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 22px;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 16px;
    line-height: 1.1;
    letter-spacing: 0.01em;
  }

  .heard-card p {
    font-size: 14px;
    line-height: 1.65;
    color: rgba(250, 247, 242, 0.75);
  }

  /* ============ PHASE 1 SCOPE ============ */

  .scope {
    background: var(--deep-green);
    padding: 140px 0;
    position: relative;
  }

  .scope-intro {
    max-width: 900px;
    margin-bottom: 80px;
  }

  .scope-intro h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(48px, 7vw, 104px);
    line-height: 0.85;
    text-transform: uppercase;
    color: var(--sand);
    letter-spacing: -0.02em;
    margin-bottom: 32px;
  }
  .scope-intro h2 .phase {
    color: var(--marines-yellow);
  }

  .scope-intro p {
    font-size: 18px;
    line-height: 1.7;
    color: rgba(250, 247, 242, 0.8);
    max-width: 720px;
  }

  .scope-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  @media (max-width: 900px) {
    .scope-columns { grid-template-columns: 1fr; gap: 32px; }
  }

  .scope-col {
    background: var(--marines-green);
    padding: 48px 40px;
    position: relative;
  }
  .scope-col.included {
    border-top: 4px solid var(--marines-yellow);
  }
  .scope-col.excluded {
    border-top: 4px solid var(--marines-red);
    background: var(--charcoal);
  }

  .scope-col-label {
    font-family: var(--font-sub);
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .included .scope-col-label { color: var(--marines-yellow); }
  .excluded .scope-col-label { color: var(--marines-red); }

  .scope-col h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 28px;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 32px;
    line-height: 1;
    letter-spacing: 0.01em;
  }

  .scope-list {
    list-style: none;
  }
  .scope-list li {
    padding: 18px 0;
    border-bottom: 1px solid rgba(250, 247, 242, 0.08);
    display: flex;
    gap: 16px;
    align-items: flex-start;
    font-size: 15px;
    line-height: 1.5;
    color: rgba(250, 247, 242, 0.9);
  }
  .scope-list li:last-child { border-bottom: none; }

  .scope-list .marker {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    margin-top: 3px;
    position: relative;
  }
  .included .scope-list .marker::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--marines-yellow);
    clip-path: polygon(0 40%, 40% 100%, 100% 10%, 85% 0, 40% 70%, 15% 30%);
  }
  .excluded .scope-list .marker::before,
  .excluded .scope-list .marker::after {
    content: '';
    position: absolute;
    top: 7px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--marines-red);
  }
  .excluded .scope-list .marker::before { transform: rotate(45deg); }
  .excluded .scope-list .marker::after { transform: rotate(-45deg); }

  .scope-list .item-title {
    font-weight: 700;
    color: var(--sand);
    display: block;
    margin-bottom: 2px;
  }
  .scope-list .item-note {
    font-size: 13px;
    color: rgba(250, 247, 242, 0.55);
  }

  /* ============ INVESTMENT SECTION ============ */

  .investment {
    background: var(--black);
    padding: 140px 0;
    position: relative;
  }

  .investment-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .investment-header h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(48px, 7vw, 104px);
    line-height: 0.85;
    text-transform: uppercase;
    color: var(--sand);
    letter-spacing: -0.02em;
    margin-top: 24px;
  }

  .invest-story {
    max-width: 1100px;
    margin: 0 auto 40px;
    background: linear-gradient(135deg, rgba(242, 181, 26, 0.14), rgba(23, 26, 23, 0.92));
    border: 1px solid rgba(242, 181, 26, 0.28);
    clip-path: polygon(0 0, calc(100% - 34px) 0, 100% 34px, 100% 100%, 34px 100%, 0 calc(100% - 34px));
    padding: 36px;
    position: relative;
    overflow: hidden;
  }
  .invest-story::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, transparent 0, transparent calc(100% - 1px), rgba(242, 181, 26, 0.08) calc(100% - 1px)),
      linear-gradient(180deg, transparent 0, transparent calc(100% - 1px), rgba(242, 181, 26, 0.06) calc(100% - 1px));
    background-size: 24px 24px;
    pointer-events: none;
    opacity: 0.35;
  }

  .invest-story-top {
    display: grid;
    grid-template-columns: 1.1fr 1.1fr 0.8fr;
    gap: 20px;
    position: relative;
    z-index: 1;
  }
  @media (max-width: 900px) {
    .invest-story-top { grid-template-columns: 1fr; }
  }

  .invest-story-block {
    padding: 24px;
    background: rgba(14, 14, 14, 0.52);
    border: 1px solid rgba(242, 181, 26, 0.16);
  }
  .invest-story-block.emphasis {
    background: var(--marines-yellow);
    color: var(--deep-green);
    border-color: var(--marines-yellow);
  }

  .invest-story-label {
    display: block;
    font-family: var(--font-sub);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(250, 247, 242, 0.62);
    margin-bottom: 12px;
  }
  .invest-story-block.emphasis .invest-story-label {
    color: rgba(23, 26, 23, 0.62);
  }

  .invest-story-price {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 8px;
  }
  .invest-story-price .currency {
    font-family: var(--font-display);
    font-size: 28px;
    color: var(--marines-yellow);
  }
  .invest-story-price .amount {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 76px);
    font-weight: 600;
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: var(--sand);
  }
  .invest-story-block.emphasis .invest-story-price .currency,
  .invest-story-block.emphasis .invest-story-price .amount {
    color: var(--deep-green);
  }
  .invest-story-price .suffix {
    font-family: var(--font-sub);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(250, 247, 242, 0.54);
    margin-left: 2px;
  }
  .invest-story-block.emphasis .invest-story-price .suffix {
    color: rgba(23, 26, 23, 0.62);
  }

  .invest-story-copy {
    font-size: 14px;
    line-height: 1.65;
    color: rgba(250, 247, 242, 0.74);
    max-width: 26ch;
  }
  .invest-story-block.emphasis .invest-story-copy {
    color: rgba(23, 26, 23, 0.76);
  }

  .invest-story-caption {
    position: relative;
    z-index: 1;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid rgba(242, 181, 26, 0.16);
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .invest-story-caption p {
    max-width: 760px;
    font-size: 15px;
    line-height: 1.7;
    color: rgba(250, 247, 242, 0.78);
  }

  .invest-story-tag {
    font-family: var(--font-stencil);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--marines-yellow);
    white-space: nowrap;
  }

  .invest-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    max-width: 1100px;
    margin: 0 auto;
  }
  @media (max-width: 900px) {
    .invest-grid { grid-template-columns: 1fr; }
  }

  .invest-card {
    background: var(--marines-green);
    padding: 56px 48px;
    position: relative;
    /* Ribbon-shape cut on top right corner */
    clip-path: polygon(0 0, calc(100% - 32px) 0, 100% 32px, 100% 100%, 0 100%);
  }

  .invest-card.primary {
    background: var(--deep-green);
    border: 2px solid var(--marines-yellow);
  }

  .invest-card-label {
    font-family: var(--font-sub);
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--marines-yellow);
    margin-bottom: 12px;
  }

  .invest-card-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 24px;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 32px;
    line-height: 1.1;
  }

  .invest-price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 12px;
  }
  .invest-price .currency {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 32px;
    color: var(--marines-yellow);
  }
  .invest-price .amount {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 88px;
    color: var(--marines-yellow);
    line-height: 0.85;
    letter-spacing: -0.03em;
  }
  .invest-price .unit {
    font-family: var(--font-sub);
    font-size: 14px;
    color: rgba(250, 247, 242, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-left: 4px;
  }

  .invest-sublabel {
