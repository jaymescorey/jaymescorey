    <script>
        // ── MANIFESTO AUDIO (Web Speech API) ──
        const manifesto = `Do it ugly. Life gets busy. Dreams quietly move to a shelf called someday. You don't need the perfect moment to begin. You just need one small step forward. Move one thing from the wish list to the lived list. Bite first. Polish later.`;
        const manifestoVoiceBtn = document.getElementById('manifesto-voice');

        if (manifestoVoiceBtn) {
            const button = manifestoVoiceBtn as HTMLButtonElement;
            button.addEventListener('click', function () {
                if ('speechSynthesis' in window) {
                    if (window.speechSynthesis.speaking) {
                        window.speechSynthesis.cancel();
                        button.textContent = '🔊 Speak';
                        button.classList.remove('speaking');
                        return;
                    }
                    const utterance = new SpeechSynthesisUtterance(manifesto);
                    utterance.rate = 0.95;
                    utterance.pitch = 0.9;
                    utterance.onend = () => {
                        button.textContent = '🔊 Speak';
                        button.classList.remove('speaking');
                    };
                    button.textContent = '[ Stop ]';
                    button.classList.add('speaking');
                    window.speechSynthesis.speak(utterance);
                } else {
                    button.textContent = 'No Audio';
                    button.disabled = true;
                }
            });
        }

        // ── MAILERLITE SUBSCRIBE ──
        const ML_URL = 'https://assets.mailerlite.com/jsonp/2182045/forms/181670405383128491/subscribe';

        function subscribeEmail(form: HTMLFormElement, onSuccess: () => void) {
            const formData = new FormData(form);
            fetch(ML_URL, { method: 'POST', body: formData })
                .then(() => onSuccess())
                .catch(() => onSuccess()); // show success either way — MailerLite JSONP doesn't need a response
        }

        function showSuccess(form: HTMLFormElement, headline: string, sub: string) {
            const msg = document.createElement('div');
            msg.className = 'signup-success';
            msg.innerHTML = `<span class="signup-success-mark">✓</span><strong>${headline}</strong><p>${sub}</p>`;
            if (form.parentNode) {
                form.parentNode.replaceChild(msg, form);
            }
            requestAnimationFrame(() => msg.classList.add('visible'));
        }

        // ── SIGNUP HANDLERS ──
        const footerSignup = document.getElementById('footer-signup') as HTMLFormElement | null;
        if (footerSignup) {
            footerSignup.addEventListener('submit', function (this: HTMLFormElement, e) {
                e.preventDefault();
                subscribeEmail(this, () => {
                    showSuccess(this, 'One Thing Moved.', 'Check your inbox — your first field report is on its way.');
                });
            });
        }

        // ── ENLIST FORM ──
        const enlistForm = document.getElementById('enlist-form') as HTMLFormElement | null;
        if (enlistForm) {
            enlistForm.addEventListener('submit', function (this: HTMLFormElement, e) {
                e.preventDefault();
                subscribeEmail(this, () => {
                    showSuccess(this, "You're In.", "One email per week. No fluff. No sponsorships. Welcome to the ugly side.");
                });
            });
        }

        const heroSignup = document.getElementById('hero-signup') as HTMLFormElement | null;
        if (heroSignup) {
            heroSignup.addEventListener('submit', function (this: HTMLFormElement, e) {
                e.preventDefault();
                subscribeEmail(this, () => {
                    showSuccess(this, "You're In.", "One email per week. No fluff. No sponsorships. Welcome to the ugly side.");
                });
            });
        }

        // ── SCROLL REVEAL ──
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('visible');
            });
        }, { threshold: 0.1 });

        document.querySelectorAll<HTMLElement>('.reveal').forEach(el => observer.observe(el));


        // ── STORY PARAGRAPH STAGGER ──
        document.querySelectorAll<HTMLElement>('.story h2, .story p').forEach((el, i) => {
            el.style.transitionDelay = `${0.15 + i * 0.12}s`;
        });

        // ── CURSOR RING ──
        if (window.matchMedia('(hover: hover)').matches) {
            const ring = document.createElement('div');
            ring.className = 'cursor-ring';
            document.body.appendChild(ring);
            let mx = 0, my = 0, rx = 0, ry = 0;
            document.addEventListener('mousemove', (e: MouseEvent) => { mx = e.clientX; my = e.clientY; ring.style.opacity = '1'; });
            document.addEventListener('mouseleave', () => { ring.style.opacity = '0'; });
            (function loopRing() {
                rx += (mx - rx) * 0.12;
                ry += (my - ry) * 0.12;
                ring.style.left = rx + 'px';
                ring.style.top = ry + 'px';
                requestAnimationFrame(loopRing);
            })();
            document.querySelectorAll<HTMLElement>('a, button, input').forEach(el => {
                el.addEventListener('mouseenter', () => { ring.style.width = '44px'; ring.style.height = '44px'; ring.style.borderColor = 'var(--yellow)'; });
                el.addEventListener('mouseleave', () => { ring.style.width = '28px'; ring.style.height = '28px'; ring.style.borderColor = 'var(--rust)'; });
            });
        }

        // ── LAB DASHBOARD FILTERS ──
        const labFilters = document.querySelectorAll<HTMLElement>('.lab-filter');
        const labRows = document.querySelectorAll<HTMLElement>('.lab-row');

        labFilters.forEach(btn => {
            btn.addEventListener('click', () => {
                labFilters.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                const filter = btn.dataset.filter;
                labRows.forEach(row => {
                    const show = filter === 'all' || row.dataset.status === filter;
                    row.style.display = show ? '' : 'none';
                });
            });
        });

        // ── LAB PROGRESS BAR ANIMATION ──
        const progressObserver = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.querySelectorAll<HTMLElement>('.lab-progress-fill').forEach(fill => {
                        fill.style.width = (fill.dataset.pct ?? '0') + '%';
                    });
                    progressObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.2 });

        const labSection = document.getElementById('lab');
        if (labSection) progressObserver.observe(labSection);

        // ── DOORS CARD TILT ──
        document.querySelectorAll<HTMLElement>('.doors-card').forEach(card => {
            card.addEventListener('mousemove', (e: MouseEvent) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                const cx = rect.width / 2;
                const cy = rect.height / 2;
                const rotX = ((y - cy) / cy) * -5;
                const rotY = ((x - cx) / cx) * 5;
                const isFeatured = card.classList.contains('doors-card--featured');
                const baseY = isFeatured ? -26 : -10;
                card.style.transform = `translateY(${baseY}px) rotateX(${rotX}deg) rotateY(${rotY}deg)`;
            });
            card.addEventListener('mouseleave', () => {
                const isFeatured = card.classList.contains('doors-card--featured');
                card.style.transform = isFeatured ? 'translateY(-16px)' : '';
            });
        });

        // ── PERMISSION BUTTON ──
        (function() {
            var messages = [
                'Ship the ugly draft.',
                'You don\'t need to be ready. You need to start.',
                'The right moment isn\'t coming. This one will do.',
                'Good enough and shipped beats perfect and stuck.',
                'You have permission. Go.',
                'Nobody gets it right the first time. That\'s not a bug.',
                'Start before you\'re ready. Edit after you\'ve learned.',
                'Done is a version of perfect.',
                'The people who built things all started before they were ready.',
                'Your draft doesn\'t need to be good. It needs to exist.',
                'Permission granted. No signature required.',
                'Move one thing today.'
            ];
            const btn = document.getElementById('permissionBtn') as HTMLElement | null;
            const msg = document.getElementById('permissionMsg') as HTMLElement | null;
            if (!btn || !msg) return;
            let last = -1;
            btn.addEventListener('click', function() {
                let idx: number;
                do { idx = Math.floor(Math.random() * messages.length); } while (idx === last && messages.length > 1);
                last = idx;
                msg.classList.remove('visible');
                setTimeout(function() {
                    msg.textContent = '\u201c' + messages[idx] + '\u201d';
                    msg.classList.add('visible');
                }, 120);
            });
        })();

        // ── PORTRAIT PARALLAX ──
        const portrait = document.querySelector('.portrait-container') as HTMLElement | null;
        if (portrait) {
            window.addEventListener('scroll', () => {
                portrait.style.transform = `rotate(1deg) translateY(${window.scrollY * 0.08}px)`;
            }, { passive: true });
        }
    </script>

    <script>
        const progressBar = document.getElementById('progress-bar') as HTMLElement | null;
        if (progressBar) {
            window.addEventListener('scroll', function() {
                const scrollTop = window.scrollY;
                const docHeight = document.documentElement.scrollHeight - window.innerHeight;
                progressBar.style.width = (scrollTop / docHeight * 100) + '%';
            }, { passive: true });
        }

        const shareBtn = document.getElementById('share-btn') as HTMLElement | null;
        const shareConfirm = document.getElementById('share-confirm') as HTMLElement | null;
        if (shareBtn && shareConfirm) {
            shareBtn.addEventListener('click', function() {
                const url = 'https://jaymescorey.com';
                if (navigator.share) {
                    navigator.share({ title: 'Jaymes Corey — Do It Ugly', url });
                } else {
                    navigator.clipboard.writeText(url).then(function() {
                        shareConfirm.classList.add('visible');
                        setTimeout(function() { shareConfirm.classList.remove('visible'); }, 2500);
                    });
                }
            });
        }
    </script>

    <!-- STICKY CTA -->
    <a href="#enlist" id="sticky-cta" aria-label="Follow the build">
        FOLLOW THE BUILD &nbsp;→
    </a>

    <style>
        #sticky-cta {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            z-index: 999;
            background: var(--yellow);
            color: var(--ink);
            font-family: 'Anton', sans-serif;
            font-size: 1rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            text-decoration: none;
            padding: 14px 24px;
            border: var(--border-width) solid var(--ink);
            box-shadow: 5px 5px 0px var(--rust);
            opacity: 0;
            pointer-events: none;
            transform: translateY(12px);
            transition: opacity 0.25s ease, transform 0.25s ease, box-shadow 0.15s ease;
        }

        #sticky-cta.visible {
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0);
        }

        #sticky-cta:hover {
            box-shadow: 8px 8px 0px var(--rust);
            transform: translate(-2px, -2px);
        }

        @media (max-width: 640px) {
            #sticky-cta {
                bottom: 1.25rem;
                right: 1.25rem;
                font-size: 0.85rem;
                padding: 12px 18px;
            }
        }
    </style>

    <script>
        (function () {
            const cta = document.getElementById('sticky-cta');
            const hero = document.querySelector('.hero') as HTMLElement | null;
            if (!cta || !hero) return;
            const observer = new IntersectionObserver(
                ([entry]) => {
                    if (!entry.isIntersecting) {
                        cta.classList.add('visible');
                    } else {
                        cta.classList.remove('visible');
                    }
                },
                { threshold: 0.1 }
            );
            observer.observe(hero);
        })();
    </script>

</BaseLayout>
