---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout
    title="Jaymes Corey | Build in Public. Launch Ugly. Move Faster."
    description="Follow a builder who homeschools by doing. Weekly field notes from ugly launches, messy experiments, and real progress in public — teaching his kids how to build freedom one imperfect step at a time."
    canonicalUrl="https://jaymescorey.com/"
    ogImage="https://jaymescorey.com/images/og-jaymes.jpg"
>
    <Fragment slot="head">
        <script type="application/ld+json">{`
        {
          "@context": "https://schema.org",
          "@type": "Person",
          "name": "Jaymes Corey",
          "url": "https://jaymescorey.com",
          "image": "https://jaymescorey.com/images/og-jaymes.jpg",
          "jobTitle": "Creative Strategist & Serial Founder",
          "description": "ADDY Award-winning creative strategist, 10x founder, and Navy veteran. Building in public while homeshooling kids and teaching freedom through imperfect action.",
          "sameAs": [
            "https://www.linkedin.com/in/jaymescorey",
            "https://x.com/jaymescorey",
            "https://www.instagram.com/jaymescorey"
          ],
          "worksFor": {
            "@type": "Organization",
            "name": "BRAVND"
          }
        }
        `}</script>
        <script type="application/ld+json">{`
        {
          "@context": "https://schema.org",
          "@type": "WebSite",
          "name": "Jaymes Corey",
          "url": "https://jaymescorey.com",
          "description": "Big ideas. Strange experiments. Notes from a builder who stopped waiting for perfect and started building in public while teaching his kids how to create freedom.",
          "author": {
            "@type": "Person",
            "name": "Jaymes Corey"
          }
        }
        `}</script>

        <style>
            /* ── THE WORK SECTION ── */
            .work-section { background: var(--paper); }

            .work-cards {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 2rem;
                margin-top: 3rem;
            }

            .work-card .card-number {
                font-family: 'Space Mono', monospace;
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                opacity: 0.5;
                margin-bottom: 0.75rem;
            }

            .work-card h3 {
                font-family: 'Anton', sans-serif;
                font-size: clamp(1.4rem, 2.5vw, 2rem);
                text-transform: uppercase;
                letter-spacing: -0.5px;
                margin-bottom: 0.75rem;
                color: var(--ink);
                line-height: 1;
            }

            .work-card .card-desc {
                font-family: 'Lora', serif;
                font-size: 0.95rem;
                line-height: 1.65;
                opacity: 0.8;
                margin-bottom: 0.75rem;
            }

            .work-card .card-result {
                font-family: 'Space Mono', monospace;
                font-size: 0.72rem;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                color: var(--rust);
                font-weight: 700;
            }

            .work-link-wrap {
                margin-top: 3rem;
                text-align: center;
            }

            .work-link {
                font-family: 'Space Mono', monospace;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                color: var(--ink);
                text-decoration: none;
                border-bottom: 3px solid var(--rust);
                padding-bottom: 3px;
                transition: color 0.1s;
            }

            .work-link:hover { color: var(--rust); }

            /* ── YELLOW EMAIL SECTION ── */
            .enlist-section-yellow {
                background: var(--yellow);
                border-top: var(--border-width) solid var(--ink);
                border-bottom: var(--border-width) solid var(--ink);
                position: relative;
                overflow: hidden;
            }

            .enlist-section-yellow::before {
                content: "JOIN THE LIST // JOIN THE LIST // JOIN THE LIST // JOIN THE LIST //";
                position: absolute;
                top: 1.5rem;
                left: 0;
                right: 0;
                font-family: 'Space Mono', monospace;
                font-size: 0.65rem;
                letter-spacing: 3px;
                color: rgba(15, 15, 15, 0.08);
                white-space: nowrap;
                overflow: hidden;
            }

            .enlist-section-yellow .enlist-form-row {
                box-shadow: 10px 10px 0px var(--ink);
            }

            .enlist-section-yellow .enlist-form-row button {
                background: var(--ink);
                color: var(--yellow);
                border-color: var(--ink);
            }

            .enlist-section-yellow .enlist-form-row button:hover {
                background: var(--rust);
                border-color: var(--rust);
                color: white;
            }

            .enlist-section-yellow .enlist-form-row input {
                border-color: var(--ink);
            }

            .enlist-section-yellow .enlist-form-row input::placeholder {
                color: rgba(15, 15, 15, 0.45);
            }

            .enlist-section-yellow .enlist-fine {
                color: var(--ink);
                opacity: 0.6;
            }

            /* ── CONTENT PILLARS ── */
            .pillars-section { background: var(--cream); }

            .pillars-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 2rem;
                margin-top: 3rem;
            }

            .pillar-card {
                background: white;
                border: var(--border-width) solid var(--ink);
                padding: 2rem 2rem 1.75rem;
                box-shadow: 6px 6px 0px var(--rust);
                transition: transform 0.1s, box-shadow 0.1s;
            }

            .pillar-card:hover {
                transform: translate(-2px, -2px);
                box-shadow: 8px 8px 0px var(--rust);
            }

            .pillar-number {
                font-family: 'Space Mono', monospace;
                font-size: 0.65rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                color: var(--rust);
                margin-bottom: 0.6rem;
            }

            .pillar-card h3 {
                font-family: 'Anton', sans-serif;
                font-size: 1.6rem;
                text-transform: uppercase;
                letter-spacing: -0.5px;
                margin-bottom: 0.75rem;
                color: var(--ink);
                line-height: 1;
            }

            .pillar-card p {
                font-family: 'Lora', serif;
                font-size: 0.9rem;
                line-height: 1.65;
                opacity: 0.75;
                color: var(--ink);
            }

            /* ── LAB SUBTICKER ── */
            .lab-subticker {
                border-top: 1px solid rgba(242, 194, 48, 0.18);
                padding: 0.85rem 0;
                overflow: hidden;
                white-space: nowrap;
                margin-top: 4rem;
            }

            .lab-subticker-track {
                display: inline-block;
                animation: tickerScroll 35s linear infinite;
                font-family: 'Space Mono', monospace;
                font-size: 0.65rem;
                letter-spacing: 3px;
                text-transform: uppercase;
                color: rgba(242, 194, 48, 0.4);
            }

            /* ── SITE FOOTER ── */
            .site-footer {
                background: linear-gradient(180deg, #101010 0%, #0b0b0b 100%);
                color: var(--paper);
                padding: 5.5rem 10% 3rem;
                border-top: var(--border-width) solid var(--yellow);
                text-align: center;
                position: relative;
                overflow: hidden;
            }

            .site-footer::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 220px;
                height: 220px;
                background: rgba(242,194,48,0.08);
                border-radius: 50%;
                box-shadow: 0 0 0 4px rgba(242,194,48,0.08);
                pointer-events: none;
            }

            .site-footer-inner {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 1.25rem;
                max-width: 1180px;
                margin: 0 auto;
                position: relative;
                z-index: 1;
            }

            .site-footer-logo {
                font-family: 'Anton', sans-serif;
                font-size: clamp(2.2rem, 4vw, 3rem);
                color: var(--yellow);
                text-decoration: none;
                text-transform: uppercase;
                letter-spacing: -1px;
                line-height: 1;
            }

            .site-footer-nav {
                display: flex;
                gap: 2rem;
                flex-wrap: wrap;
                justify-content: center;
            }

            .site-footer-nav a {
                font-family: 'Space Mono', monospace;
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                color: rgba(255,255,255,0.85);
                text-decoration: none;
                opacity: 0.75;
                transition: opacity 0.15s, color 0.15s, transform 0.15s;
            }

            .site-footer-nav a:hover {
                opacity: 1;
                color: var(--yellow);
                transform: translateY(-1px);
            }

            .site-footer-social {
                display: flex;
                gap: 1.5rem;
                flex-wrap: wrap;
                justify-content: center;
            }

            .site-footer-social a {
                font-family: 'Space Mono', monospace;
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                color: rgba(255,255,255,0.75);
                text-decoration: none;
                opacity: 0.7;
                transition: opacity 0.15s, color 0.15s, transform 0.15s;
            }

            .site-footer-social a:hover {
                opacity: 1;
                color: var(--yellow);
                transform: translateY(-1px);
            }

            .site-footer-divider {
                width: min(720px, 100%);
                height: 1px;
                background: rgba(242, 194, 48, 0.18);
                margin: 0.75rem auto;
            }

            .site-footer-tags {
                display: flex;
                gap: 1rem;
                flex-wrap: wrap;
                justify-content: center;
            }

            .site-footer-tags span {
                font-family: 'Space Mono', monospace;
                font-size: 0.68rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                color: var(--yellow);
                opacity: 0.9;
                padding: 0.55rem 0.9rem;
                border: 1px solid rgba(242,194,48,0.18);
                background: rgba(242,194,48,0.07);
                border-radius: 999px;
            }

            .site-footer-copy {
                font-family: 'Space Mono', monospace;
                font-size: 0.72rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                opacity: 0.45;
                margin: 0;
                padding-top: 0.75rem;
            }

            .site-footer-copy a {
                color: inherit;
                text-decoration: underline;
            }

            @media (min-width: 900px) {
                .site-footer-inner {
                    align-items: center;
                }
            }

            /* ── HI I'M JAYMES ── */
            .intro-section { background: var(--paper); }

            .intro-stats {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                border: var(--border-width) solid var(--ink);
                margin: 2.5rem 0 3.5rem;
            }

            .intro-stat {
                padding: 1.5rem 1.25rem;
                text-align: center;
                border-right: var(--border-width) solid var(--ink);
            }

            .intro-stat:last-child { border-right: none; }

            .intro-stat-num {
                display: block;
                font-family: 'Anton', sans-serif;
                font-size: clamp(2.2rem, 4vw, 3.5rem);
                line-height: 1;
                letter-spacing: -1px;
                color: var(--ink);
            }

            .intro-stat-label {
                display: block;
                font-family: 'Space Mono', monospace;
                font-size: 0.58rem;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                color: var(--rust);
                margin-top: 0.5rem;
            }

            .intro-grid {
                display: grid;
                grid-template-columns: 1fr 300px;
                gap: 4rem;
                align-items: start;
            }

            .intro-body p {
                font-family: 'Lora', serif;
                font-size: clamp(1rem, 1.5vw, 1.15rem);
                line-height: 1.8;
                color: var(--ink);
                margin-bottom: 1.25rem;
            }

            .intro-anchor {
                font-family: 'Space Mono', monospace;
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                color: var(--rust);
                margin-top: 2rem;
            }

            .intro-pullquote {
                background: var(--ink);
                border: var(--border-width) solid var(--ink);
                box-shadow: 8px 8px 0px var(--rust);
                padding: 2.5rem 2rem 2rem;
                position: relative;
                transform: rotate(var(--r, 1.5deg));
                margin-top: 0.5rem;
            }

            .intro-pullquote-text {
                font-family: 'Anton', sans-serif;
                font-size: clamp(1.6rem, 2.2vw, 2.1rem);
                text-transform: uppercase;
                line-height: 1.1;
                letter-spacing: -0.5px;
                color: var(--yellow);
            }

            .intro-pullquote-attr {
                font-family: 'Space Mono', monospace;
                font-size: 0.6rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                color: rgba(246,241,231,0.4);
                margin-top: 1.5rem;
            }


            /* ── LIVE LAB DASHBOARD ── */
            .lab-dashboard-section { background: var(--poster-black); color: var(--paper); }
            .lab-dashboard-section .section-label { color: var(--yellow); }
            .lab-dashboard-section .section-title { color: var(--paper); }

            .lab-dashboard-lead {
                font-family: 'Lora', serif;
                font-size: 1.05rem;
                max-width: 580px;
                opacity: 0.65;
                line-height: 1.7;
                margin-top: 0.5rem;
                margin-bottom: 2.5rem;
            }

            .lab-filters {
                display: flex;
                gap: 0.75rem;
                flex-wrap: wrap;
                margin-bottom: 2rem;
                padding: 1rem 1rem 0.75rem;
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(246,241,231,0.12);
                border-radius: 0.25rem;
            }

            .lab-filter {
                font-family: 'Space Mono', monospace;
                font-size: 0.65rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                padding: 0.5rem 1rem;
                border: 2px solid rgba(246,241,231,0.2);
                background: transparent;
                color: var(--paper);
                cursor: pointer;
                opacity: 0.7;
                transition: all 0.15s;
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

            .lab-filter:hover { opacity: 1; border-color: var(--yellow); color: var(--yellow); }

            .lab-filter.active {
                opacity: 1;
                background: var(--yellow);
                border-color: var(--yellow);
                color: var(--ink);
            }

            .lab-filter-count {
                background: rgba(0,0,0,0.2);
                padding: 0.1rem 0.4rem;
                font-size: 0.6rem;
            }

            .lab-filter.active .lab-filter-count { background: rgba(15,15,15,0.15); }

            .lab-rows { display: flex; flex-direction: column; gap: 0; }

            .lab-row {
                display: grid;
                grid-template-columns: 120px 1fr 1fr 200px;
                gap: 1.5rem;
                align-items: center;
                padding: 1.4rem 1.5rem;
                border: 1px solid rgba(246,241,231,0.08);
                border-bottom: none;
                background: rgba(255,255,255,0.04);
                transition: background 0.2s, transform 0.2s;
            }

            .lab-row:last-child { border-bottom: 1px solid rgba(246,241,231,0.08); }
            .lab-row:hover { background: rgba(246,241,231,0.08); transform: translateX(-2px); }
            .lab-row[data-status="live"] { border-color: rgba(242,194,48,0.22); }
            .lab-row[data-status="killed"] { opacity: 0.9; }

            .lab-row[data-status="killed"] { opacity: 0.45; }

            .lab-badge {
                font-family: 'Space Mono', monospace;
                font-size: 0.6rem;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                padding: 0.3rem 0.65rem;
                border: 1px solid;
                white-space: nowrap;
            }

            .lab-badge--live { color: var(--yellow); border-color: var(--yellow); }
            .lab-badge--building { color: #7dd3fc; border-color: #7dd3fc; }
            .lab-badge--killed { color: var(--rust); border-color: var(--rust); }
            .lab-badge--idea { color: rgba(246,241,231,0.4); border-color: rgba(246,241,231,0.2); }

            .lab-row-domain {
                font-family: 'Anton', sans-serif;
                font-size: 1.1rem;
                text-transform: uppercase;
                letter-spacing: -0.5px;
                color: var(--paper);
                line-height: 1.1;
            }

            .lab-row-focus {
                font-family: 'Space Mono', monospace;
                font-size: 0.65rem;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                color: var(--yellow);
                opacity: 0.7;
                margin-top: 0.3rem;
            }

            .lab-row-result {
                font-family: 'Lora', serif;
                font-size: 0.95rem;
                opacity: 0.7;
                font-style: italic;
                line-height: 1.7;
            }

            .lab-progress-label {
                display: flex;
                justify-content: space-between;
                font-family: 'Space Mono', monospace;
                font-size: 0.58rem;
                text-transform: uppercase;
                letter-spacing: 1px;
                opacity: 0.45;
                margin-bottom: 0.4rem;
            }

            .lab-progress-track {
                height: 6px;
                background: rgba(246,241,231,0.12);
                overflow: hidden;
                border-radius: 99px;
            }

            .lab-progress-fill {
                height: 100%;
                width: 0;
                transition: width 1s cubic-bezier(0.23, 1, 0.32, 1);
                border-radius: 99px;
            }

            .lab-progress-fill--live { background: var(--yellow); }
            .lab-progress-fill--building { background: #7dd3fc; }
            .lab-progress-fill--killed { background: var(--rust); }
            .lab-progress-fill--idea { background: rgba(246,241,231,0.2); }

            .lab-dashboard-note {
                font-family: 'Space Mono', monospace;
                font-size: 0.65rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                opacity: 0.3;
                margin-top: 2rem;
                text-align: center;
            }

            @media (max-width: 768px) {
                .lab-row {
                    grid-template-columns: 1fr 1fr;
                    grid-template-rows: auto auto;
                    gap: 0.75rem;
                }
                .lab-row-result { display: none; }
                .lab-row-progress { grid-column: 1 / -1; }
            }

            /* ── KIDS APPROVED ── */
            .kids-approved-section {
                background: var(--paper);
                text-align: center;
                border-top: var(--border-width) solid var(--ink);
                padding-bottom: 4rem;
            }

            .kids-stamp-wrap {
                display: flex;
                justify-content: center;
                margin: 2.5rem 0 1.5rem;
            }

            .kids-stamp {
                position: relative;
                width: 250px;
                height: 250px;
                filter: drop-shadow(6px 6px 0px var(--rust));
                animation: kids-stamp-idle 5s ease-in-out infinite;
                will-change: transform;
                cursor: default;
                transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275),
                            filter 0.3s ease;
            }

            .kids-stamp::before {
                content: 'BRAND SEAL';
                position: absolute;
                top: -20px;
                left: 50%;
                transform: translateX(-50%);
                font-family: 'Space Mono', monospace;
                font-size: 0.7rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: var(--ink);
                background: var(--yellow);
                padding: 0.35rem 0.9rem;
                border: 2px solid var(--ink);
                border-radius: 999px;
            }

            .kids-stamp:hover {
                animation: none;
                transform: rotate(-8deg) scale(1.05);
                filter: drop-shadow(8px 8px 0px var(--rust));
            }

            @keyframes kids-stamp-idle {
                0%, 100% { transform: rotate(9deg); }
                50%       { transform: rotate(14deg); }
            }

            .kids-stamp-ring {
                position: relative;
                width: 100%;
                height: 100%;
            }

            .kids-stamp-ring svg {
                position: absolute;
                top: 0; left: 0;
                width: 100%; height: 100%;
            }

            .kids-stamp-dog {
                position: absolute;
                top: 50%; left: 50%;
                transform: translate(-50%, -50%);
                width: 110px; height: 110px;
                border-radius: 50%;
                overflow: hidden;
                border: 4px solid var(--ink);
                background: var(--yellow);
            }

            .kids-stamp-dog img {
                width: 100%; height: 100%;
                object-fit: cover;
                object-position: center top;
            }

            .kids-stamp-note {
                font-family: 'Space Mono', monospace;
                font-size: 0.95rem;
                color: rgba(15,15,15,0.7);
                letter-spacing: 0.12em;
                margin-top: 1rem;
                text-transform: uppercase;
            }

            /* ── FREEDOM TO SECTION ── */
            .freedom-section {
                background: var(--paper);
                border-top: var(--border-width) solid var(--ink);
            }

            .freedom-lead {
                font-family: 'Lora', serif;
                font-size: 1.1rem;
                opacity: 0.75;
                margin-top: 0.5rem;
                max-width: 620px;
                line-height: 1.75;
            }

            .freedom-list {
                margin-top: 3rem;
                display: grid;
                gap: 1rem;
                max-width: 820px;
                margin-left: auto;
                margin-right: auto;
                padding: 1rem;
                background: rgba(15,15,15,0.03);
                border: 1px solid rgba(15,15,15,0.08);
                border-radius: 1rem;
            }

            .freedom-item {
                display: flex;
                align-items: baseline;
                gap: 1.5rem;
                padding: 1.25rem 0;
                border-bottom: 1px solid rgba(15,15,15,0.08);
            }

            .freedom-item:last-child { border-bottom: none; }

            .freedom-num {
                font-family: 'Space Mono', monospace;
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                color: var(--rust);
                white-space: nowrap;
                flex-shrink: 0;
                padding-top: 0.2rem;
            }

            .freedom-text {
                font-family: 'Anton', sans-serif;
                font-size: clamp(1.4rem, 2.3vw, 2rem);
                text-transform: uppercase;
                letter-spacing: -0.5px;
                line-height: 1.15;
                color: var(--ink);
                max-width: 88ch;
            }

            .freedom-text em {
                font-style: normal;
                color: var(--rust);
                -webkit-text-stroke: 0;
            }

            .freedom-cta-wrap {
                margin-top: 3rem;
                display: flex;
                flex-direction: column;
                gap: 1.5rem;
                align-items: flex-start;
                max-width: 720px;
            }

            .freedom-cta-wrap p {
                font-family: 'Lora', serif;
                font-size: 1.05rem;
                max-width: 580px;
                line-height: 1.8;
                opacity: 0.75;
                margin-bottom: 0;
            }

            /* ── LAB DISPATCHES FEED ── */
            .dispatch-section {
                background: var(--ink);
                color: var(--paper);
            }
            .dispatch-section .section-label { color: var(--yellow); }
            .dispatch-section .section-title { color: var(--paper); }
            .dispatch-section .section-title .outline {
                -webkit-text-stroke-color: var(--yellow);
            }

            .dispatch-lead {
                font-family: 'Lora', serif;
                font-size: clamp(1rem, 1.8vw, 1.2rem);
                max-width: 600px;
                margin-bottom: 2.5rem;
                opacity: 0.85;
                line-height: 1.6;
            }

