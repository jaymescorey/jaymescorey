    <script>
    // @ts-nocheck
    (function() {
        var container = document.getElementById('cloth-container');
        var canvas = document.getElementById('cloth-canvas');
        var fallback = document.getElementById('cloth-fallback');
        var hint = document.getElementById('cloth-hint');

        // On mobile, skip WebGL entirely and show the static fallback
        if (window.innerWidth <= 768) {
            fallback.style.display = 'block';
            canvas.style.display = 'none';
            if (hint) hint.style.display = 'none';
            return;
        }

        var gl = canvas.getContext('webgl');
        if (!gl) {
            fallback.style.display = 'block';
            canvas.style.display = 'none';
            if (hint) hint.style.display = 'none';
            return;
        }

        // ── Textures ──
        function mkTex(drawFn) {
            var tc = document.createElement('canvas');
            tc.width = 1024; tc.height = 2048;
            var c = tc.getContext('2d');
            c.scale(2, 2);
            drawFn(c, 512, 1024);
            var t = gl.createTexture();
            gl.bindTexture(gl.TEXTURE_2D, t);
            gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, tc);
            gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
            gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
            gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
            gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
            return t;
        }

        var texWish = mkTex(function(c, W) {
            var H = 1024;

            // Background — ink dark
            c.fillStyle = '#1A1A1A';
            c.fillRect(0, 0, W, H);

            // Subtle dot grid texture
            c.fillStyle = 'rgba(242,194,48,0.07)';
            for (var gy = 24; gy < H; gy += 28) {
                for (var gx = 24; gx < W; gx += 28) { c.fillRect(gx, gy, 2, 2); }
            }

            // Yellow header band
            c.fillStyle = '#F2C230';
            c.fillRect(0, 0, W, 86);

            // Small label in header
            c.fillStyle = 'rgba(28,28,28,0.55)';
            c.font = '500 12px monospace';
            c.textAlign = 'left';
            c.fillText('00.2 // WISH LIST', 20, 22);

            // "WISH" bold in header band
            c.fillStyle = '#1C1C1C';
            c.font = 'bold 58px monospace';
