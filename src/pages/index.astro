        });

        // ── WebGL Setup ──
        var aspect = 1;
        function resize() {
            canvas.width = container.clientWidth * window.devicePixelRatio;
            canvas.height = container.clientHeight * window.devicePixelRatio;
            gl.viewport(0, 0, canvas.width, canvas.height);
            aspect = canvas.width / canvas.height;
        }
        window.addEventListener('resize', resize);
        resize();

        var vsSource = 'attribute vec3 a_pos;attribute vec3 a_norm;attribute vec2 a_uv;uniform mat4 u_proj;uniform mat4 u_view;varying vec3 v_norm;varying vec2 v_uv;void main(){v_norm=a_norm;v_uv=a_uv;gl_Position=u_proj*u_view*vec4(a_pos,1.0);}';
        var fsSource = 'precision mediump float;varying vec3 v_norm;varying vec2 v_uv;uniform sampler2D u_tex;void main(){vec3 norm=normalize(v_norm);if(!gl_FrontFacing)norm=-norm;vec3 l1=normalize(vec3(0.4,0.8,0.6));vec3 l2=normalize(vec3(-0.5,-0.2,0.8));float d1=max(dot(norm,l1),0.0);float d2=max(dot(norm,l2),0.0);vec4 c=texture2D(u_tex,v_uv);gl_FragColor=vec4(c.rgb*(0.55+d1*0.4+d2*0.2),c.a);}';
        function mkShader(type,src){var s=gl.createShader(type);gl.shaderSource(s,src);gl.compileShader(s);return s;}
        var prog=gl.createProgram();
        gl.attachShader(prog,mkShader(gl.VERTEX_SHADER,vsSource));
        gl.attachShader(prog,mkShader(gl.FRAGMENT_SHADER,fsSource));
        gl.linkProgram(prog); gl.useProgram(prog);
        var aPos=gl.getAttribLocation(prog,'a_pos'),aNorm=gl.getAttribLocation(prog,'a_norm'),aUv=gl.getAttribLocation(prog,'a_uv');
        var uProj=gl.getUniformLocation(prog,'u_proj'),uView=gl.getUniformLocation(prog,'u_view');

        // ── Shared Geometry ──
        var nX=20, nY=44, nP=nX*nY, cW=3.6, cH=5.0;
        var idx: number[] = [];
        for(var y=0;y<nY-1;y++) for(var x=0;x<nX-1;x++){var i=y*nX+x;idx.push(i,i+1,i+nX,i+1,i+nX+1,i+nX);}
        var sharedIdxBuf=gl.createBuffer();
        gl.bindBuffer(gl.ELEMENT_ARRAY_BUFFER,sharedIdxBuf);
        gl.bufferData(gl.ELEMENT_ARRAY_BUFFER,new Uint16Array(idx),gl.STATIC_DRAW);
        var uvD=new Float32Array(nP*2);
        for(var y=0;y<nY;y++) for(var x=0;x<nX;x++){var i=y*nX+x;uvD[i*2]=x/(nX-1);uvD[i*2+1]=y/(nY-1);}
        var sharedUvBuf=gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER,sharedUvBuf);
        gl.bufferData(gl.ARRAY_BUFFER,uvD,gl.STATIC_DRAW);

        // ── Cloth Factory ──
        function makeCloth(offsetX, tex) {
            var parts=[],posD=new Float32Array(nP*3),normD=new Float32Array(nP*3);
            for(var y=0;y<nY;y++) for(var x=0;x<nX;x++){
                var px=offsetX+(x/(nX-1)-0.5)*cW, py=-(y/(nY-1))*cH;
                parts.push({x:px,y:py,z:0,ox:px,oy:py,oz:0});
            }
            var cons=[];
            function addC(a,b){var p=parts[a],q=parts[b],dx=q.x-p.x,dy=q.y-p.y,dz=q.z-p.z;cons.push({p1:a,p2:b,rest:Math.sqrt(dx*dx+dy*dy+dz*dz)});}
            for(var y=0;y<nY;y++) for(var x=0;x<nX;x++){
                var i=y*nX+x;
                if(x<nX-1)addC(i,i+1); if(y<nY-1)addC(i,i+nX);
                if(x<nX-1&&y<nY-1){addC(i,i+nX+1);addC(i+1,i+nX);}
                if(x<nX-2)addC(i,i+2); if(y<nY-2)addC(i,i+nX*2);
            }
            var posBuf=gl.createBuffer(), normBuf=gl.createBuffer();
            return {parts:parts,cons:cons,posD:posD,normD:normD,posBuf:posBuf,normBuf:normBuf,tex:tex};
        }

        var cloths = [makeCloth(-2.4, texWish), makeCloth(2.4, texLived)];
        gl.enable(gl.DEPTH_TEST);

        var proj=new Float32Array(16),view=new Float32Array(16);
        function setPers(out,fovy,asp,near,far){var f=1/Math.tan(fovy/2),nf=1/(near-far);out.fill(0);out[0]=f/asp;out[5]=f;out[10]=(far+near)*nf;out[11]=-1;out[14]=2*far*near*nf;}
        function setTrans(out,x,y,z){out.fill(0);out[0]=1;out[5]=1;out[10]=1;out[15]=1;out[12]=x;out[13]=y;out[14]=z;}

        var cam={x:0,y:-2.5,z:7.8}, fov=45*Math.PI/180;
        var ptrX=0,ptrY=0,rafId: number | null = null,time=0,hintFaded=false;
        var grabbedCloth=-1,grabIdx=-1,grabD=0;

        function updatePtr(e){var r=canvas.getBoundingClientRect();ptrX=((e.clientX-r.left)/r.width)*2-1;ptrY=-(((e.clientY-r.top)/r.height)*2-1);}
        function getRay(){var t=Math.tan(fov/2),dx=ptrX*aspect*t,dy=ptrY*t,dz=-1,l=Math.sqrt(dx*dx+dy*dy+dz*dz);return{ox:cam.x,oy:cam.y,oz:cam.z,dx:dx/l,dy:dy/l,dz:dz/l};}

        canvas.addEventListener('pointerdown',function(e){
            canvas.setPointerCapture(e.pointerId); updatePtr(e);
            var ray=getRay(),best=-1,bestCl=-1,minD=Infinity;
            for(var ci=0;ci<2;ci++){
                var cl=cloths[ci];
                for(var i=0;i<nP;i++){
                    var p=cl.parts[i],vx=p.x-ray.ox,vy=p.y-ray.oy,vz=p.z-ray.oz;
                    var t=vx*ray.dx+vy*ray.dy+vz*ray.dz;
                    var qx=ray.ox+ray.dx*t-p.x,qy=ray.oy+ray.dy*t-p.y,qz=ray.oz+ray.dz*t-p.z;
                    var d=Math.sqrt(qx*qx+qy*qy+qz*qz);
                    if(d<minD&&d<0.8){minD=d;best=i;bestCl=ci;grabD=t;}
                }
            }
            if(best!==-1){grabIdx=best;grabbedCloth=bestCl;if(!hintFaded){hint.style.opacity='0';hintFaded=true;}}
        });
        canvas.addEventListener('pointermove',function(e){
            updatePtr(e);
            if(grabIdx!==-1&&grabbedCloth!==-1){var ray=getRay(),p=cloths[grabbedCloth].parts[grabIdx];p.x=ray.ox+ray.dx*grabD;p.y=ray.oy+ray.dy*grabD;p.z=ray.oz+ray.dz*grabD;p.ox=p.x;p.oy=p.y;p.oz=p.z;}
        });
        canvas.addEventListener('pointerup',function(){grabIdx=-1;grabbedCloth=-1;});
        canvas.addEventListener('pointercancel',function(){grabIdx=-1;grabbedCloth=-1;});

        function updateCloth(cl: any, grabI: number) {
            var wX=Math.sin(time*1.5)*0.0015,wZ=Math.cos(time*1.1)*0.0015;
            for(var i=0;i<nP;i++){
                if(i<nX||i===grabI)continue;
                var p=cl.parts[i],vx=(p.x-p.ox)*0.985,vy=(p.y-p.oy)*0.985,vz=(p.z-p.oz)*0.985;
                p.ox=p.x;p.oy=p.y;p.oz=p.z;
                var wf=p.y/-cH;
                p.x+=vx+wX*wf; p.y+=vy-0.007; p.z+=vz+wZ*wf;
            }
            for(var iter=0;iter<15;iter++) for(var i=0;i<cl.cons.length;i++){
                var c=cl.cons[i],p1=cl.parts[c.p1],p2=cl.parts[c.p2];
                var dx=p2.x-p1.x,dy=p2.y-p1.y,dz=p2.z-p1.z,dist=Math.sqrt(dx*dx+dy*dy+dz*dz);
                var w1=(c.p1<nX||c.p1===grabI)?0:1,w2=(c.p2<nX||c.p2===grabI)?0:1,ws=w1+w2;
                if(ws>0){var df=(dist-c.rest)/(dist*ws),ox=dx*df,oy=dy*df,oz=dz*df;if(w1){p1.x+=ox;p1.y+=oy;p1.z+=oz;}if(w2){p2.x-=ox;p2.y-=oy;p2.z-=oz;}}
            }
            cl.normD.fill(0);
            for(var i=0;i<nP;i++){var p=cl.parts[i];cl.posD[i*3]=p.x;cl.posD[i*3+1]=p.y;cl.posD[i*3+2]=p.z;}
            for(var i=0;i<idx.length;i+=3){
                var a=idx[i],b=idx[i+1],cc=idx[i+2];
                var ax=cl.posD[a*3],ay=cl.posD[a*3+1],az=cl.posD[a*3+2];
                var bx=cl.posD[b*3],by=cl.posD[b*3+1],bz=cl.posD[b*3+2];
                var cx=cl.posD[cc*3],cy=cl.posD[cc*3+1],cz=cl.posD[cc*3+2];
                var dx1=bx-ax,dy1=by-ay,dz1=bz-az,dx2=cx-ax,dy2=cy-ay,dz2=cz-az;
                var nx=dy1*dz2-dz1*dy2,ny=dz1*dx2-dx1*dz2,nz=dx1*dy2-dy1*dx2;
                cl.normD[a*3]+=nx;cl.normD[a*3+1]+=ny;cl.normD[a*3+2]+=nz;
                cl.normD[b*3]+=nx;cl.normD[b*3+1]+=ny;cl.normD[b*3+2]+=nz;
                cl.normD[cc*3]+=nx;cl.normD[cc*3+1]+=ny;cl.normD[cc*3+2]+=nz;
            }
        }

        function drawCloth(cl: any) {
            gl.bindTexture(gl.TEXTURE_2D,cl.tex);
            gl.bindBuffer(gl.ARRAY_BUFFER,cl.posBuf); gl.bufferData(gl.ARRAY_BUFFER,cl.posD,gl.DYNAMIC_DRAW);
            gl.enableVertexAttribArray(aPos); gl.vertexAttribPointer(aPos,3,gl.FLOAT,false,0,0);
            gl.bindBuffer(gl.ARRAY_BUFFER,cl.normBuf); gl.bufferData(gl.ARRAY_BUFFER,cl.normD,gl.DYNAMIC_DRAW);
            gl.enableVertexAttribArray(aNorm); gl.vertexAttribPointer(aNorm,3,gl.FLOAT,false,0,0);
            gl.bindBuffer(gl.ARRAY_BUFFER,sharedUvBuf); gl.enableVertexAttribArray(aUv); gl.vertexAttribPointer(aUv,2,gl.FLOAT,false,0,0);
            gl.bindBuffer(gl.ELEMENT_ARRAY_BUFFER,sharedIdxBuf);
            gl.drawElements(gl.TRIANGLES,idx.length,gl.UNSIGNED_SHORT,0);
        }

        function render() {
            time+=0.016;
            updateCloth(cloths[0], grabbedCloth===0 ? grabIdx : -1);
            updateCloth(cloths[1], grabbedCloth===1 ? grabIdx : -1);
            gl.clearColor(0.1098,0.1098,0.1098,1.0);
            gl.clear(gl.COLOR_BUFFER_BIT|gl.DEPTH_BUFFER_BIT);
            setPers(proj,fov,aspect,0.1,100.0);
            setTrans(view,-cam.x,-cam.y,-cam.z);
            gl.uniformMatrix4fv(uProj,false,proj); gl.uniformMatrix4fv(uView,false,view);
            drawCloth(cloths[0]);
            drawCloth(cloths[1]);
            rafId=requestAnimationFrame(render);
        }

        var visObs=new IntersectionObserver(function(entries: IntersectionObserverEntry[]){
            if(entries[0].isIntersecting){if(!rafId)rafId=requestAnimationFrame(render);}
            else{if(rafId){cancelAnimationFrame(rafId);rafId=null;}}
        },{threshold:0.05});
        if (container) visObs.observe(container);
    })();
    </script>

