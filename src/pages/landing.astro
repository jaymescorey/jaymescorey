        /* ── Footer ── */
        .site-footer {
            background: var(--ink);
            padding: 1.75rem 10%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
            border-top: 2px solid rgba(242,194,48,0.12);
