---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout
    title="Work | Jaymes Corey — Built to Move"
    description="A collection of work built to move ideas forward. Permission-based brand strategy and creative campaigns made for real momentum, not just polish."
    canonicalUrl="https://jaymescorey.com/portfolio"
    ogImage="https://jaymescorey.com/images/og-jaymes.jpg"
>
    <Fragment slot="head">
        <script type="application/ld+json">{`
        {
          "@context": "https://schema.org",
          "@type": "CollectionPage",
          "name": "The Work — Jaymes Corey",
          "url": "https://jaymescorey.com/portfolio",
          "description": "A collection of work built to move ideas forward. Permission-based brand strategy and creative campaigns made for real momentum.",
          "author": {
            "@type": "Person",
            "name": "Jaymes Corey",
            "url": "https://jaymescorey.com"
          },
          "breadcrumb": {
            "@type": "BreadcrumbList",
            "itemListElement": [
              { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jaymescorey.com/" },
              { "@type": "ListItem", "position": 2, "name": "The Work", "item": "https://jaymescorey.com/portfolio" }
            ]
          }
        }
        `}</script>

        <!-- Preload gallery images so they're ready before the overlay opens -->
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_1.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_2.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_3.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_4.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_5.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_6.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_7.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_8.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_9.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_10.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_11.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_12.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_13.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_14.png">
        <link rel="preload" as="image" href="/images/addy-award-jaymes-corey_15.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts1.jpeg">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-1.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-2.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-3.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-4.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-5.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-6.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-7.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-8.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-9.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-10.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-11.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-12.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-13.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-14.png">
        <link rel="preload" as="image" href="/images/Jaymes-Corey-All-Birds-Concepts-15.png">

        <style>
            /* ── PORTFOLIO HERO ── */
            .port-hero {
                background: var(--ink);
                border-bottom: 6px solid var(--yellow);
                padding: 7rem 10% 6rem;
                position: relative;
                overflow: hidden;
            }

            .port-hero::before {
                content: "THE WORK // THE WORK // THE WORK // THE WORK // THE WORK // THE WORK // THE WORK //";
                position: absolute;
                bottom: 1.5rem;
                left: 0; right: 0;
                font-family: 'Space Mono', monospace;
                font-size: 0.65rem;
                letter-spacing: 3px;
                color: rgba(242,194,48,0.12);
                white-space: nowrap;
                overflow: hidden;
            }

            .port-hero::after {
                content: "";
                position: absolute;
                top: 0; left: 40px; bottom: 0;
                width: 2px;
                background: rgba(201, 74, 43, 0.25);
            }

            .port-hero-inner {
                position: relative;
                z-index: 2;
            }

            .port-hero h1 {
                font-size: clamp(5rem, 13vw, 10rem);
                color: var(--yellow);
                margin-bottom: 1.5rem;
                letter-spacing: -3px;
            }

            .port-hero h1 em {
                display: block;
                color: var(--paper);
                -webkit-text-stroke: 3px var(--yellow);
                paint-order: stroke fill;
                font-style: normal;
            }

            .port-hero-sub {
                font-family: 'Lora', serif;
                font-style: italic;
                font-size: clamp(1.1rem, 2vw, 1.5rem);
                color: rgba(246, 241, 231, 0.75);
                max-width: 600px;
                line-height: 1.5;
            }

            .port-philosophy {
                margin-top: 2.5rem;
                display: flex;
                gap: 3rem;
                flex-wrap: wrap;
            }

            .port-philosophy-item {
                display: flex;
                flex-direction: column;
                gap: 0.3rem;
            }

            .port-philosophy-item .label {
                font-family: 'Space Mono', monospace;
                font-size: 0.65rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                color: var(--rust);
            }

            .port-philosophy-item .value {
                font-family: 'Anton', sans-serif;
                font-size: 1.2rem;
                text-transform: uppercase;
                color: var(--yellow);
                letter-spacing: 1px;
            }

            /* ── FEATURED CASE ── */
            .featured-case {
                padding: 8rem 10%;
                background: var(--paper);
                border-bottom: var(--border-width) solid var(--ink);
            }

            .featured-case-inner {
                display: grid;
                grid-template-columns: 1fr 1.8fr;
                gap: 4rem;
                align-items: start;
            }

            .featured-case-info {
                position: relative;
            }

            .case-number {
                font-family: 'Space Mono', monospace;
                font-size: 0.7rem;
                letter-spacing: 3px;
                text-transform: uppercase;
                opacity: 0.5;
                margin-bottom: 1rem;
                display: block;
            }

            .featured-case-info h2 {
                font-family: 'Anton', sans-serif;
                font-size: clamp(3rem, 6vw, 5.5rem);
                text-transform: uppercase;
                line-height: 0.88;
                letter-spacing: -2px;
                margin-bottom: 1.5rem;
            }

            .featured-case-info h2 span {
                display: block;
                color: var(--rust);
            }

            .case-tags {
                display: flex;
                flex-wrap: wrap;
                gap: 0.5rem;
                margin-bottom: 2rem;
            }

            .case-tag {
                font-family: 'Space Mono', monospace;
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: 1px;
                padding: 4px 12px;
                border: 2px solid var(--ink);
                background: transparent;
            }

            .case-tag.award {
                background: var(--yellow);
                border-color: var(--ink);
                font-weight: 700;
            }

            .featured-case-info .case-description {
                font-family: 'Lora', serif;
                font-size: 1.1rem;
                line-height: 1.75;
                max-width: 540px;
                margin-bottom: 2rem;
                opacity: 0.85;
            }

            .case-cta {
                display: inline-block;
                padding: 1rem 2.5rem;
                font-family: 'Anton', sans-serif;
                font-size: 1.1rem;
                text-decoration: none;
                text-transform: uppercase;
                background: var(--ink);
                color: var(--yellow);
                border: var(--border-width) solid var(--ink);
                box-shadow: 6px 6px 0px var(--rust);
                transition: 0.1s;
                cursor: pointer;
            }

            .case-cta:hover {
                transform: translate(-2px, -2px);
                box-shadow: 8px 8px 0px var(--rust);
            }

            /* ── FEATURED VISUAL PANEL ── */
            .featured-visual {
                position: relative;
            }

            .featured-img-wrap {
                position: relative;
                border: var(--border-width) solid var(--ink);
                box-shadow: 18px 18px 0px var(--ink);
                transform: rotate(1.5deg);
                overflow: hidden;
                background: #1a0a2e;
            }

            .featured-img-wrap img {
                width: 100%;
                display: block;
            }

            /* ── UGLY APPROVED STAMP ── */
            .ugly-stamp {
                position: absolute;
                top: -28px;
                right: -28px;
                width: 130px;
                height: 130px;
                z-index: 10;
                transform: rotate(12deg);
                filter: drop-shadow(4px 4px 0px rgba(0,0,0,0.5));
                transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                cursor: default;
            }

            .ugly-stamp:hover {
                transform: rotate(-6deg) scale(1.1);
            }

            .ugly-stamp-ring {
                position: relative;
                width: 130px;
                height: 130px;
            }

            .ugly-stamp-ring svg {
                position: absolute;
                top: 0; left: 0;
                width: 100%;
                height: 100%;
            }

            .ugly-stamp-dog {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                width: 68px;
                height: 68px;
                border-radius: 50%;
                overflow: hidden;
                border: 3px solid var(--ink);
                background: var(--yellow);
            }

            .ugly-stamp-dog img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                object-position: center top;
            }

            .tape-h {
                position: absolute;
                top: -12px;
                left: 50%;
                transform: translateX(-50%);
                width: 80px;
                height: 22px;
                background: rgba(242, 194, 48, 0.7);
                border: 1px solid rgba(0,0,0,0.15);
                z-index: 5;
            }

            /* ── CAMPAIGN GALLERY / CORKBOARD ── */
            .corkboard {
                columns: 3;
                column-gap: 2.5rem;
                margin-top: 4rem;
            }

            @media (max-width: 900px) { .corkboard { columns: 2; } }
            @media (max-width: 560px) { .corkboard { columns: 1; } }

            .gallery-pin {
                break-inside: avoid;
                position: relative;
                margin-bottom: 2.5rem;
                transform: rotate(var(--r, 0deg));
                transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.25s ease;
                background: white;
                border: var(--border-width) solid var(--ink);
                box-shadow: 8px 8px 0px rgba(0,0,0,0.6);
                padding: 8px 8px 0;
                display: inline-block;
                width: 100%;
            }

            .gallery-pin:hover {
                transform: rotate(0deg) translateY(-8px);
                box-shadow: 14px 14px 0px var(--rust);
                z-index: 10;
                position: relative;
            }

            .gallery-pin img {
                width: 100%;
                display: block;
            }

            .gallery-tape {
                position: absolute;
                top: -13px;
                left: 50%;
                transform: translateX(-50%);
                width: 70px;
                height: 20px;
                background: rgba(242, 194, 48, 0.65);
                border: 1px solid rgba(0,0,0,0.12);
                z-index: 5;
            }

            /* ── DESIGN PHILOSOPHY STRIP ── */
            .philosophy-strip {
                background: var(--rust);
                border-top: var(--border-width) solid var(--ink);
                border-bottom: var(--border-width) solid var(--ink);
                padding: 5rem 10%;
            }

            .philosophy-strip h2 {
                font-family: 'Anton', sans-serif;
                font-size: clamp(2.5rem, 5vw, 4.5rem);
                text-transform: uppercase;
                line-height: 0.9;
                color: var(--ink);
                margin-bottom: 2rem;
                letter-spacing: -1px;
            }

            .philosophy-strip h2 em {
                font-style: normal;
                color: var(--yellow);
                -webkit-text-stroke: 2px var(--ink);
                paint-order: stroke fill;
            }

            .philosophy-strip p {
                font-family: 'Lora', serif;
                font-style: italic;
                font-size: clamp(1rem, 2vw, 1.3rem);
                color: var(--ink);
                max-width: 680px;
                line-height: 1.65;
                opacity: 0.9;
            }

            /* ── MINI FOOTER ── */
            .port-footer {
                background: var(--ink);
                padding: 3rem 10%;
                display: flex;
                justify-content: space-between;
                align-items: center;
                flex-wrap: wrap;
                gap: 1rem;
                border-top: var(--border-width) solid var(--yellow);
            }

            .port-footer a {
                font-family: 'Anton', sans-serif;
                font-size: 1.1rem;
                color: var(--yellow);
                text-decoration: none;
                text-transform: uppercase;
                letter-spacing: 1px;
                transition: color 0.2s;
            }

            .port-footer a:hover { color: var(--rust); }

            .port-footer-meta {
                font-family: 'Space Mono', monospace;
                font-size: 0.65rem;
                color: rgba(246,241,231,0.3);
                text-transform: uppercase;
                letter-spacing: 2px;
            }

            /* ── HERO HEADLINE + MASCOT ── */
            .hero-headline-row {
                display: flex;
                align-items: flex-end;
                justify-content: space-between;
            }

            .hero-mascot {
                width: clamp(260px, 28vw, 400px);
                flex-shrink: 0;
                transform-origin: bottom center;
                animation: mascot-float 4s ease-in-out infinite;
                filter: drop-shadow(3px 6px 0px rgba(0,0,0,0.5));
                cursor: pointer;
            }

            .hero-mascot img { width: 100%; display: block; }

            @keyframes mascot-float {
                0%, 100% { transform: translateY(0px) rotate(-1deg); }
                50%       { transform: translateY(-12px) rotate(1deg); }
            }

            .hero-mascot:hover {
                animation: mascot-wag 0.5s ease-in-out infinite;
                filter: drop-shadow(4px 8px 0px var(--rust));
            }

            @keyframes mascot-wag {
                0%   { transform: rotate(-6deg) translateY(-4px); }
                25%  { transform: rotate(6deg)  translateY(-4px); }
                50%  { transform: rotate(-4deg) translateY(-8px); }
                75%  { transform: rotate(4deg)  translateY(-4px); }
                100% { transform: rotate(-6deg) translateY(-4px); }
            }

            @media (max-width: 768px) { .hero-mascot { display: none; } }

            /* ── CASE STUDY OVERLAY ── */
            .case-overlay {
                position: fixed;
                top: 0; right: 0; bottom: 0; left: 0;
                z-index: 3000;
                background: var(--paper);
                transform: translateX(100%);
                transition: transform 0.55s cubic-bezier(0.77, 0, 0.175, 1),
                            visibility 0s 0.55s;
                visibility: hidden;
                pointer-events: none;
                overflow-y: auto;
                overflow-x: hidden;
                -webkit-overflow-scrolling: touch;
            }

            .case-overlay.open {
                transform: translateX(0);
                transition: transform 0.55s cubic-bezier(0.77, 0, 0.175, 1),
                            visibility 0s 0s;
                visibility: visible;
                pointer-events: auto;
            }

            /* Sticky top bar */
            .case-overlay-nav {
                position: sticky;
                top: 0;
                z-index: 10;
                background: var(--ink);
                border-bottom: 4px solid var(--yellow);
                padding: 1rem 5%;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
            }

            .case-overlay-close {
                font-family: 'Space Mono', monospace;
                font-size: 0.7rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: var(--yellow);
                background: none;
                border: none;
                cursor: pointer;
                padding: 0;
                transition: color 0.2s;
                white-space: nowrap;
            }

            .case-overlay-close:hover { color: var(--rust); }

            .case-overlay-id {
                font-family: 'Space Mono', monospace;
                font-size: 0.6rem;
                letter-spacing: 3px;
                text-transform: uppercase;
                color: rgba(242,194,48,0.4);
            }

            .case-overlay-share {
                font-family: 'Space Mono', monospace;
                font-size: 0.65rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: var(--ink);
                background: var(--yellow);
                border: none;
                padding: 7px 16px;
                cursor: pointer;
                box-shadow: 3px 3px 0 var(--rust);
                transition: transform 0.15s, box-shadow 0.15s;
                white-space: nowrap;
            }

            .case-overlay-share:hover {
                transform: translate(-1px, -1px);
                box-shadow: 4px 4px 0 var(--rust);
            }

            .case-overlay-share.copied {
                background: var(--rust);
                color: white;
            }

            /* Overlay hero */
            .case-overlay-hero {
                background: var(--ink);
                padding: 5rem 10% 4rem;
                border-bottom: 4px solid var(--rust);
                position: relative;
                overflow: hidden;
            }

            .case-overlay-hero::after {
                content: attr(data-bg-text);
                position: absolute;
                bottom: -1.5rem;
                right: 4%;
                font-family: 'Anton', sans-serif;
                font-size: 14vw;
                color: rgba(242,194,48,0.04);
                text-transform: uppercase;
                white-space: nowrap;
                line-height: 1;
                pointer-events: none;
            }

            .case-overlay-hero h2 {
                font-family: 'Anton', sans-serif;
                font-size: clamp(3.5rem, 8vw, 7rem);
                text-transform: uppercase;
                line-height: 0.88;
                letter-spacing: -2px;
                color: var(--yellow);
                margin: 1rem 0 2rem;
            }

            .case-overlay-hero h2 span {
                display: block;
                color: var(--paper);
                -webkit-text-stroke: 3px var(--yellow);
                paint-order: stroke fill;
            }

            .case-overlay-hero .case-tag {
                border-color: rgba(246,241,231,0.25);
                color: rgba(246,241,231,0.7);
            }

            .case-overlay-hero .case-tag.award {
                background: var(--yellow);
                border-color: var(--yellow);
                color: var(--ink);
            }

            /* Overlay body */
            .case-overlay-body {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 5rem;
                padding: 5rem 10%;
                background: var(--paper);
                border-bottom: var(--border-width) solid var(--ink);
                align-items: start;
            }

            .case-overlay-lead img {
                width: 100%;
                display: block;
                border: var(--border-width) solid var(--ink);
                box-shadow: 14px 14px 0 var(--ink);
                transform: rotate(1deg);
            }

            .case-overlay-copy .case-description {
                font-family: 'Lora', serif;
                font-size: clamp(1rem, 1.8vw, 1.2rem);
                line-height: 1.8;
                margin-bottom: 1.5rem;
                opacity: 0.85;
            }

            .case-overlay-copy .case-tags { margin-top: 2rem; }

            /* Overlay gallery */
            .case-overlay-gallery {
                background: var(--poster-black);
                border-top: var(--border-width) solid var(--rust);
                padding: 5rem 8%;
            }

            .case-overlay-gallery .section-label { color: var(--rust); }
            .case-overlay-gallery .section-title { color: var(--yellow); }

            /* Overlay footer */
            .case-overlay-footer {
                background: var(--ink);
                padding: 2.5rem 10%;
                display: flex;
                justify-content: space-between;
                align-items: center;
                flex-wrap: wrap;
                gap: 1rem;
                border-top: var(--border-width) solid var(--yellow);
            }

            .case-overlay-footer .port-footer-meta {
                font-family: 'Space Mono', monospace;
                font-size: 0.6rem;
                color: rgba(246,241,231,0.25);
                text-transform: uppercase;
                letter-spacing: 2px;
            }

            /* ── RESPONSIVE ── */
            @media (max-width: 900px) {
                .featured-case-inner {
                    grid-template-columns: 1fr;
                    gap: 3rem;
                }
                .featured-visual { order: -1; }
                .featured-img-wrap { transform: rotate(0.5deg); }
                .case-overlay-body { grid-template-columns: 1fr; gap: 3rem; }
                .case-overlay-id { display: none; }
            }

            @media (max-width: 600px) {
                .port-hero h1 { letter-spacing: -2px; }
                .port-philosophy { gap: 1.5rem; }
            }
        </style>
    </Fragment>

    <div id="progress-bar"></div>

    <Nav page="portfolio" />

    <!-- Mobile Menu Overlay -->
    <div class="mobile-menu-overlay" id="mobileMenu" role="dialog" aria-modal="true" aria-label="Navigation menu">
        <button class="mobile-menu-close" id="mobileMenuClose" aria-label="Close menu">✕</button>
        <nav>
            <a href="/" class="mob-link"><span class="mob-num">01 /</span>Home</a>
            <a href="/about" class="mob-link"><span class="mob-num">02 /</span>About</a>
            <a href="/field-report" class="mob-link"><span class="mob-num">03 /</span>Field Report</a>
            <a href="/portfolio" class="mob-cta mob-link"><span class="mob-num">&#8594;</span>The Work</a>
        </nav>
        <div class="mobile-menu-footer">[ DO_IT_UGLY ] // Build It Before You're Ready.</div>
    </div>

    <!-- ── HERO ── -->
    <section class="port-hero">
        <div class="port-hero-inner">
            <span class="section-label" style="color: var(--yellow); opacity: 0.7;">00.0 // The Work</span>
            <div class="hero-headline-row">
                <h1>The<br><em>Work.</em></h1>
                <div class="hero-mascot" title="Jaymes Corey">
                    <img src="https://api.iconify.design/ph:dog-bold.svg?color=%23F2C230" alt="Jaymes Corey Mascot" style="filter: drop-shadow(0 0 12px rgba(242,194,48,0.4));">
                </div>
            </div>
            <p class="port-hero-sub">
                Big ideas. Unconventional thinking. Permission-based design —
                rules broken on purpose, not by accident.
                Sometimes an award follows.
            </p>
            <div class="port-philosophy">
                <div class="port-philosophy-item">
                    <span class="label">Approach</span>
                    <span class="value">Permission-Based</span>
                </div>
                <div class="port-philosophy-item">
                    <span class="label">Discipline</span>
