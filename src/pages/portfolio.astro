    <script>
        // ── CASE STUDY OVERLAY ──
        function openCase(id: string) {
            const overlay = document.getElementById('case-' + id);
            if (!overlay) return;
            overlay.classList.add('open');
            overlay.scrollTop = 0;
            document.documentElement.style.overflow = 'hidden';
            document.body.style.overflow = 'hidden';
            history.pushState({ overlay: id }, '', '#' + id);
            const shareBtn = overlay.querySelector<HTMLElement>('.case-overlay-share');
            if (shareBtn) { shareBtn.textContent = 'Share This →'; shareBtn.classList.remove('copied'); }
        }

        function closeCase() {
            document.querySelectorAll<HTMLElement>('.case-overlay.open').forEach(function(o) {
                o.classList.remove('open');
            });
            document.documentElement.style.overflow = '';
            document.body.style.overflow = '';
            history.pushState(null, '', window.location.pathname);
        }

        function shareCase(id: string, btn: HTMLElement) {
            const url = window.location.origin + window.location.pathname + '#' + id;
            if (navigator.share) {
                navigator.share({ title: document.title, url: url });
            } else {
                navigator.clipboard.writeText(url).then(function() {
                    btn.textContent = 'Link Copied ✓';
                    btn.classList.add('copied');
                    setTimeout(function() {
                        btn.textContent = 'Share This →';
                        btn.classList.remove('copied');
                    }, 2500);
                });
            }
        }

        // Wire up open/close buttons
        const openAliceBtn = document.getElementById('open-alice');
        const closeAliceTop = document.getElementById('close-alice-top');
        const closeAliceBottom = document.getElementById('close-alice-bottom');
        const shareAliceBtn = document.getElementById('share-alice');

        const openAllbirdsBtn = document.getElementById('open-allbirds');
        const closeAllbirdsTop = document.getElementById('close-allbirds-top');
        const closeAllbirdsBottom = document.getElementById('close-allbirds-bottom');
        const shareAllbirdsBtn = document.getElementById('share-allbirds');

        if (openAliceBtn) openAliceBtn.addEventListener('click', function() { openCase('alice-strange-brew'); });
        if (closeAliceTop) closeAliceTop.addEventListener('click', closeCase);
        if (closeAliceBottom) closeAliceBottom.addEventListener('click', closeCase);
        if (shareAliceBtn) shareAliceBtn.addEventListener('click', function(this: HTMLElement) { shareCase('alice-strange-brew', this); });

        if (openAllbirdsBtn) openAllbirdsBtn.addEventListener('click', function() { openCase('all-birds'); });
        if (closeAllbirdsTop) closeAllbirdsTop.addEventListener('click', closeCase);
        if (closeAllbirdsBottom) closeAllbirdsBottom.addEventListener('click', closeCase);
        if (shareAllbirdsBtn) shareAllbirdsBtn.addEventListener('click', function(this: HTMLElement) { shareCase('all-birds', this); });

        // Browser back button closes overlay
        window.addEventListener('popstate', function() {
            var open = document.querySelector('.case-overlay.open');
            if (open) {
                open.classList.remove('open');
                document.documentElement.style.overflow = '';
                document.body.style.overflow = '';
            }
        });

        // Escape key closes overlay
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeCase();
        });

        // Open overlay on load if URL contains a hash
        window.addEventListener('load', function() {
            var hash = window.location.hash.slice(1);
            if (hash) openCase(hash);
        });

        // ── SCROLL REVEAL ──
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('visible');
            });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

        // ── CURSOR RING ──
        if (window.matchMedia('(hover: hover)').matches) {
            const ring = document.createElement('div');
            ring.className = 'cursor-ring';
            document.body.appendChild(ring);
            let mx = 0, my = 0, rx = 0, ry = 0;
            document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; ring.style.opacity = '1'; });
            document.addEventListener('mouseleave', () => { ring.style.opacity = '0'; });
            (function loopRing() {
                rx += (mx - rx) * 0.12;
                ry += (my - ry) * 0.12;
                ring.style.left = rx + 'px';
                ring.style.top = ry + 'px';
                requestAnimationFrame(loopRing);
            })();
            document.querySelectorAll('a, button').forEach(el => {
                el.addEventListener('mouseenter', () => { ring.style.width = '44px'; ring.style.height = '44px'; ring.style.borderColor = 'var(--yellow)'; });
                el.addEventListener('mouseleave', () => { ring.style.width = '28px'; ring.style.height = '28px'; ring.style.borderColor = 'var(--rust)'; });
            });
        }

        // ── TEXT SCRAMBLE on hero ──
        function scrambleEl(el: HTMLElement, finalText: string, delay: number) {
            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ?!#$%*>';
            let n = 0;
            setTimeout(() => {
                const iv = setInterval(() => {
                    el.textContent = finalText.split('').map((ch, i) => {
                        if (ch === ' ' || ch === '.') return ch;
                        return i < Math.floor(n) ? finalText[i] : chars[Math.floor(Math.random() * chars.length)];
                    }).join('');
                    n += 0.5;
                    if (n >= finalText.length) { el.textContent = finalText; clearInterval(iv); }
                }, 40);
            }, delay);
        }

        window.addEventListener('load', () => {
            const em = document.querySelector<HTMLElement>('.port-hero h1 em');
            if (em) scrambleEl(em, 'Work.', 500);
        });

        // ── MOBILE MENU ──
        (function() {
            const hamburger = document.getElementById('navHamburger');
            const mobileMenu = document.getElementById('mobileMenu');
            const closeBtn = document.getElementById('mobileMenuClose');
            if (!hamburger || !mobileMenu || !closeBtn) return;

            const navHamburger = hamburger;
            const navMobileMenu = mobileMenu;
            const navCloseBtn = closeBtn;

            const closeMobileMenu = () => {
                navHamburger.classList.remove('open');
                navMobileMenu.classList.remove('open');
                document.body.style.overflow = '';
            };

            navHamburger.addEventListener('click', function() {
                const isOpen = navMobileMenu.classList.toggle('open');
                navHamburger.classList.toggle('open', isOpen);
                document.body.style.overflow = isOpen ? 'hidden' : '';
            });

            navCloseBtn.addEventListener('click', closeMobileMenu);
        })();    </script>

</BaseLayout>
