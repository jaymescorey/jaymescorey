---
interface Props {
    page?: 'home' | 'about' | 'portfolio' | 'fieldReport';
}
const { page = 'home' } = Astro.props;
---

<nav>
    <a href="/" class="nav-logo">
        <span class="nav-logo-jaymes">JAYMES</span><span class="nav-logo-corey">COREY<span class="nav-logo-dot">.</span></span>
    </a>
    {page === 'home' && (
        <div class="nav-links">
            <a href="#start">Start Here</a>
            <a href="#lab">The Lab</a>
            <a href="/about">About</a>
            <a href="/field-report">Field Report</a>
            <a href="#enlist" class="nav-cta">Follow The Build</a>
        </div>
    )}
    {page === 'about' && (
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/about" class="active">About</a>
            <a href="/portfolio">The Work</a>
            <a href="/field-report" class="nav-cta">Field Report</a>
        </div>
    )}
    {page === 'portfolio' && (
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/portfolio" class="nav-cta active" aria-current="page">The Work</a>
            <a href="/about">About</a>
            <a href="/field-report">Field Report</a>
        </div>
    )}
    {page === 'fieldReport' && (
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/about">About</a>
            <a href="/portfolio">The Work</a>
            <a href="/field-report" class="active" aria-current="page">Field Report</a>
        </div>
    )}
    {page === 'home' && (
        <button class="nav-hamburger" id="navHamburger" aria-label="Open menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
        </button>
    )}
    {page === 'about' && (
        <>
            <span class="nav-tag">[ ABOUT_ME ]</span>
            <button class="nav-hamburger" id="navHamburger" aria-label="Open menu">
                <span></span><span></span><span></span>
            </button>
        </>
    )}
    {page === 'portfolio' && (
        <>
            <span class="nav-tag">[ PORTFOLIO_v1.0 ]</span>
            <button class="nav-hamburger" id="navHamburger" aria-label="Open menu">
                <span></span><span></span><span></span>
            </button>
        </>
    )}
    {page === 'fieldReport' && (
        <>
            <span class="nav-tag">[ FIELD_REPORT ]</span>
            <button class="nav-hamburger" id="navHamburger" aria-label="Open menu">
                <span></span><span></span><span></span>
            </button>
        </>
    )}
</nav>

<script>
    const hamburger = document.getElementById('navHamburger');
    const mobileMenu = document.getElementById('mobileMenu');
    const mobileClose = document.getElementById('mobileMenuClose');
    if (hamburger && mobileMenu && mobileClose) {
        hamburger.addEventListener('click', () => {
            mobileMenu.classList.add('open');
            hamburger.setAttribute('aria-expanded', 'true');
        });
        mobileClose.addEventListener('click', () => {
            mobileMenu.classList.remove('open');
            hamburger.setAttribute('aria-expanded', 'false');
        });
    }
</script>
