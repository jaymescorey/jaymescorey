---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';

interface Props {
    title: string;
    description: string;
    canonicalUrl: string;
    pubDate: string;
    readTime: string;
    category: string;
    postTitle: string;
    slug: string;
}

const { title, description, canonicalUrl, pubDate, readTime, category, postTitle, slug } = Astro.props;

const displayDate = new Date(pubDate).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric'
});

const allPosts = [
    {
        slug: 'building-in-public',
        title: 'Why I Stopped Waiting to Be Ready (And Started Building in Public)',
        excerpt: 'Most people wait for perfect. I waited for years. Here\'s what changed when I started building out loud.',
        date: 'Mar 15, 2026',
        readTime: '6 min',
        category: 'WRITTEN',
    },
    {
        slug: 'one-person-business-model',
        title: 'The One-Person Business Model: Build Without a Team, Funding, or Permission',
        excerpt: 'The old startup playbook is broken for most people. Here\'s the model that actually works.',
        date: 'Mar 8, 2026',
        readTime: '7 min',
        category: 'WRITTEN',
    },
    {
        slug: 'navy-discipline-entrepreneur',
        title: 'What 4 Years in the Navy Taught Me About Building a Business',
        excerpt: 'Mission clarity. Shipping ugly. Adapting without perfect intel. The Navy built habits that matter.',
        date: 'Mar 1, 2026',
        readTime: '6 min',
        category: 'WRITTEN',
    },
    {
        slug: 'present-dad-entrepreneur',
        title: 'The Real ROI: Why Presence With Your Kids Is Worth Building For',
        excerpt: 'Money is a terrible reason to build a business. Presence is the real return.',
        date: 'Feb 22, 2026',
        readTime: '5 min',
        category: 'WRITTEN',
    },
    {
        slug: 'zero-dollar-startup',
        title: 'The $0 Startup: Building Multiple Businesses Without Outside Investment',
        excerpt: 'No investors. No co-founders. No startup capital. Here\'s what zero investment actually looks like.',
        date: 'Feb 15, 2026',
        readTime: '7 min',
        category: 'WRITTEN',
    },
];

const morePosts = allPosts.filter(p => p.slug !== slug).slice(0, 3);

const schema = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": postTitle,
    "url": canonicalUrl,
    "datePublished": pubDate,
    "author": {
        "@type": "Person",
        "name": "Jaymes Corey",
        "url": "https://jaymescorey.com"
    },
    "publisher": {
        "@type": "Person",
        "name": "Jaymes Corey",
        "url": "https://jaymescorey.com"
    },
    "description": description,
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": canonicalUrl
    }
};
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl}>
    <Fragment slot="head">
        <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
    </Fragment>

    <style is:global>
            /* ── POST HERO ── */
            .post-hero {
                background: var(--ink);
                color: var(--paper);
                padding: 8rem 10% 5rem;
                position: relative;
                overflow: hidden;
                border-bottom: var(--border-width) solid var(--yellow);
            }

            .post-hero::before {
                content: "FIELD REPORT // FIELD REPORT // FIELD REPORT //";
                position: absolute;
                bottom: 1.5rem;
                left: 0;
                right: 0;
                font-family: 'Space Mono', monospace;
                font-size: 0.65rem;
                letter-spacing: 3px;
                color: rgba(242,194,48,0.06);
                white-space: nowrap;
                overflow: hidden;
            }

            .post-category {
                display: inline-block;
                font-family: 'Space Mono', monospace;
                font-size: 0.72rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: var(--yellow);
                opacity: 0.85;
                margin-bottom: 1.25rem;
            }

            .post-hero h1 {
                font-family: 'Anton', sans-serif;
                font-size: clamp(2.25rem, 4.5vw, 4rem);
                line-height: 1.0;
                margin-bottom: 2rem;
                max-width: 860px;
                color: var(--paper);
                text-transform: uppercase;
            }

            .post-meta {
                display: flex;
                gap: 0.75rem;
                align-items: center;
                font-family: 'Space Mono', monospace;
                font-size: 0.7rem;
                letter-spacing: 1.5px;
                text-transform: uppercase;
                color: rgba(246,241,231,0.55);
            }

            .post-meta .sep {
                color: var(--yellow);
                opacity: 0.5;
            }

            /* ── BODY ── */
            .post-body {
                background: var(--paper);
                padding: 5rem 10%;
            }

            .post-body-inner {
                max-width: 740px;
                margin: 0 auto;
            }

            .post-back {
                display: inline-block;
                font-family: 'Space Mono', monospace;
                font-size: 0.7rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: var(--rust);
                text-decoration: none;
                margin-bottom: 3rem;
                border-bottom: 2px solid var(--rust);
                padding-bottom: 2px;
                transition: color 0.15s, border-color 0.15s;
            }

            .post-back:hover {
                color: var(--ink);
                border-bottom-color: var(--ink);
            }

            .post-body-inner h2 {
                font-family: 'Anton', sans-serif;
                font-size: clamp(1.5rem, 2.5vw, 2rem);
                text-transform: uppercase;
                color: var(--ink);
                margin-top: 3.5rem;
                margin-bottom: 1rem;
                line-height: 1.1;
                border-left: 4px solid var(--yellow);
                padding-left: 1rem;
            }

            .post-body-inner p {
                font-family: 'Lora', serif;
                font-size: 1.05rem;
                line-height: 1.9;
                color: var(--ink);
                margin-bottom: 1.5rem;
            }

            .post-body-inner blockquote {
                border-left: 4px solid var(--rust);
                margin: 2.5rem 0;
                padding: 1.25rem 1.75rem;
                background: var(--cream);
                font-family: 'Lora', serif;
                font-style: italic;
                font-size: 1.15rem;
                line-height: 1.75;
                color: var(--ink);
                box-shadow: 6px 6px 0px var(--rust);
            }

            .post-body-inner ul,
            .post-body-inner ol {
                font-family: 'Lora', serif;
                font-size: 1.05rem;
                line-height: 1.9;
                margin-bottom: 1.5rem;
                padding-left: 1.5rem;
                color: var(--ink);
            }

            .post-body-inner li {
                margin-bottom: 0.5rem;
            }

            /* ── SPRINT CALLOUT ── */
            .sprint-callout {
                background: var(--yellow);
                border-top: var(--border-width) solid var(--ink);
                border-bottom: var(--border-width) solid var(--ink);
                padding: 3rem 10%;
            }

            .sprint-callout-inner {
                max-width: 860px;
                margin: 0 auto;
                display: flex;
                align-items: center;
                gap: 2.5rem;
                flex-wrap: wrap;
            }

            .sprint-callout-label {
                font-family: 'Space Mono', monospace;
                font-size: 0.65rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: var(--ink);
                opacity: 0.6;
                white-space: nowrap;
            }

            .sprint-callout-body {
                flex: 1;
                min-width: 200px;
            }

            .sprint-callout-body h3 {
                font-family: 'Anton', sans-serif;
                font-size: clamp(1.2rem, 2vw, 1.6rem);
                text-transform: uppercase;
                color: var(--ink);
                line-height: 1.05;
                margin-bottom: 0.4rem;
            }

            .sprint-callout-body p {
                font-family: 'Lora', serif;
                font-size: 0.9rem;
                line-height: 1.7;
                color: rgba(15,15,15,0.7);
            }

            .sprint-callout .btn {
                white-space: nowrap;
                flex-shrink: 0;
                background: var(--ink);
                color: var(--yellow);
                box-shadow: 4px 4px 0px var(--rust);
            }

            .sprint-callout .btn:hover {
                box-shadow: 7px 7px 0px var(--rust);
            }

            @media (max-width: 640px) {
                .sprint-callout { padding: 2.5rem 6vw; }
                .sprint-callout-inner { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
                .sprint-callout-label { display: none; }
            }

            /* ── MORE DISPATCHES ── */
            .more-section {
                background: var(--poster-black);
                padding: 5rem 10%;
                border-top: var(--border-width) solid var(--ink);
                border-bottom: var(--border-width) solid var(--yellow);
            }

            .more-header {
                display: flex;
                align-items: baseline;
                gap: 1.5rem;
                margin-bottom: 2.5rem;
            }

            .more-header h2 {
                font-family: 'Anton', sans-serif;
                font-size: clamp(1.75rem, 3vw, 2.5rem);
                text-transform: uppercase;
                color: var(--paper);
                line-height: 1;
            }

            .more-header span {
                font-family: 'Space Mono', monospace;
                font-size: 0.65rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: var(--yellow);
                opacity: 0.6;
            }

            .more-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 1.5rem;
            }

            .more-card {
                background: var(--ink);
                border: var(--border-width) solid rgba(246,241,231,0.1);
                padding: 1.75rem;
                text-decoration: none;
                color: inherit;
                display: flex;
                flex-direction: column;
                gap: 0.75rem;
                transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
            }

            .more-card:hover {
                border-color: var(--yellow);
                box-shadow: 6px 6px 0px var(--rust);
                transform: translate(-2px, -2px);
            }

            .more-card-tag {
                font-family: 'Space Mono', monospace;
                font-size: 0.62rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: var(--rust);
            }

            .more-card-title {
                font-family: 'Anton', sans-serif;
                font-size: 1.05rem;
                text-transform: uppercase;
                color: var(--paper);
                line-height: 1.1;
            }

            .more-card-excerpt {
                font-family: 'Lora', serif;
                font-size: 0.85rem;
                line-height: 1.7;
                color: rgba(246,241,231,0.55);
                flex: 1;
            }

            .more-card-meta {
                font-family: 'Space Mono', monospace;
                font-size: 0.6rem;
                letter-spacing: 1.5px;
                text-transform: uppercase;
                color: var(--yellow);
                opacity: 0.5;
                padding-top: 1rem;
                border-top: 1px solid rgba(246,241,231,0.08);
                display: flex;
                justify-content: space-between;
            }

            /* ── EMAIL CTA ── */
            .post-cta-section {
                background: var(--ink);
                color: var(--paper);
                padding: 6rem 10%;
                text-align: center;
            }

            .post-cta-label {
                font-family: 'Space Mono', monospace;
                font-size: 0.72rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: var(--yellow);
                opacity: 0.75;
                margin-bottom: 1rem;
            }

            .post-cta-section h2 {
                font-family: 'Anton', sans-serif;
                font-size: clamp(2.5rem, 5vw, 4rem);
                line-height: 0.95;
                margin-bottom: 1.25rem;
                text-transform: uppercase;
            }

            .post-cta-section p {
                font-family: 'Lora', serif;
                font-size: 1rem;
                line-height: 1.8;
                max-width: 580px;
                margin: 0 auto 2.5rem;
                color: rgba(246,241,231,0.82);
            }

            /* ── RESPONSIVE ── */
            @media (max-width: 860px) {
                .more-grid { grid-template-columns: 1fr 1fr; }
            }

            @media (max-width: 640px) {
                .post-hero { padding: 6rem 6vw 4rem; }
                .post-body { padding: 3.5rem 6vw; }
                .more-section { padding: 3.5rem 6vw; }
                .more-grid { grid-template-columns: 1fr; }
                .post-cta-section { padding: 4rem 6vw; }
            }
    </style>

    <div id="progress-bar"></div>
    <Nav page="fieldReport" />

    <div class="mobile-menu-overlay" id="mobileMenu" role="dialog" aria-modal="true" aria-label="Navigation menu">
        <button class="mobile-menu-close" id="mobileMenuClose" aria-label="Close menu">✕</button>
        <nav>
            <a href="/" class="mob-link"><span class="mob-num">01 /</span>Home</a>
            <a href="/about" class="mob-link"><span class="mob-num">02 /</span>About</a>
            <a href="/portfolio" class="mob-link"><span class="mob-num">03 /</span>The Work</a>
            <a href="/field-report" class="mob-cta mob-link"><span class="mob-num">→</span>Field Report</a>
        </nav>
        <div class="mobile-menu-footer">[ FIELD_REPORT ] // No fluff dispatches.</div>
    </div>

    <header class="post-hero">
        <span class="post-category">{category} // Field Report</span>
        <h1>{postTitle}</h1>
        <div class="post-meta">
            <span>{displayDate}</span>
            <span class="sep">◆</span>
            <span>{readTime} read</span>
        </div>
    </header>

    <div class="post-body">
        <div class="post-body-inner">
            <a href="/field-report" class="post-back">← All dispatches</a>
            <slot />
        </div>
    </div>

    <!-- SPRINT CALLOUT -->
    <aside class="sprint-callout">
        <div class="sprint-callout-inner">
            <span class="sprint-callout-label">◆ Limited — 10 clients at a time</span>
            <div class="sprint-callout-body">
                <h3>Need someone to build with you?</h3>
                <p>The 30-Day Sprint is 4 weeks of focused work — calls, email access, and a real plan. $2,500. Apply when there's a seat.</p>
            </div>
            <a href="/sprint" class="btn">See The Sprint &nbsp;→</a>
        </div>
    </aside>

    <!-- MORE DISPATCHES -->
    <section class="more-section">
        <div class="more-header">
            <h2>More from the field</h2>
            <span>Keep reading →</span>
        </div>
        <div class="more-grid">
            {morePosts.map(post => (
                <a href={`/field-report/${post.slug}`} class="more-card">
                    <span class="more-card-tag">{post.category}</span>
                    <span class="more-card-title">{post.title}</span>
                    <p class="more-card-excerpt">{post.excerpt}</p>
                    <div class="more-card-meta">
                        <span>{post.date}</span>
                        <span>{post.readTime} read</span>
                    </div>
                </a>
            ))}
        </div>
    </section>

    <section class="post-cta-section">
        <p class="post-cta-label">00.1 // Follow The Build</p>
        <h2>Get the field report<br>in your inbox.</h2>
        <p>One email per week. Raw experiments, real numbers, no fluff. The behind-the-scenes nobody posts.</p>
        <a href="/#enlist" class="btn">Follow The Build &nbsp;→</a>
    </section>

</BaseLayout>
